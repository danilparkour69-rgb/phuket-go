# Local PostgreSQL from ../docker-compose.yml.
# Keep an explicit username and password in Prisma URLs even on local machines.
# Peer-auth style URLs without a user can produce opaque Prisma schema-engine errors.
DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/phuket_go?schema=public"

# Test PostgreSQL from ../docker-compose.yml. Backend integration, Docker smoke,
# and Playwright E2E use this shape and must target the *_test database.
TEST_DATABASE_URL="postgresql://superuser:superpassword@localhost:54330/phuket_go_test?schema=public"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:4321,http://localhost:4321,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"

# Local admin bootstrap for `bun run --cwd backend seed:admin`.
# The default values are for local development only; set your own values when
# sharing a machine or when you want a stable test admin account.
LOCAL_ADMIN_EMAIL="admin@phuket-go.local"
LOCAL_ADMIN_PASSWORD="admin12345"
LOCAL_ADMIN_DISPLAY_NAME="Phuket Go Admin"
LOCAL_ADMIN_RESET_PASSWORD="false"

# Optional DigitalOcean Spaces storage. Leave blank until the product needs
# uploads, media, or other persistent files.
SPACES_REGION=""
SPACES_BUCKET=""
SPACES_ENDPOINT=""
SPACES_CDN_BASE_URL=""
SPACES_ACCESS_KEY_ID=""
SPACES_SECRET_ACCESS_KEY=""
SPACES_UPLOAD_MAX_BYTES="10485760"
SPACES_UPLOAD_URL_TTL_SECONDS="900"
SPACES_DOWNLOAD_URL_TTL_SECONDS="300"
SPACES_PUBLIC_CACHE_CONTROL="public, max-age=31536000, immutable"

# Tripadvisor Content API integration.
TRIPADVISOR_API_KEY=""
TRIPADVISOR_API_BASE_URL="https://api.content.tripadvisor.com/api/v1"
TRIPADVISOR_ALLOW_REFRESH="false"
TRIPADVISOR_SYNC_STALE_HOURS="24"
TRIPADVISOR_MAX_REQUESTS_PER_RUN="10"
TRIPADVISOR_DAILY_MAX_REQUESTS="200"
TRIPADVISOR_REQUEST_TIMEOUT_MS="8000"

# Optional Google Sheets lead export. Keep disabled for local development until
# a Google service account and spreadsheet are prepared.
GOOGLE_SHEETS_ENABLED="false"
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_LEADS_SHEET_NAME="Заявки"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""

# Optional Telegram lead notifications. Keep disabled locally until the bot
# token and admin chat are prepared. Partner notifications use partner
# telegram_chat_id from the database when it is known.
TELEGRAM_NOTIFICATIONS_ENABLED="false"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""
# Optional local smoke-test target. Not used by the running backend.
TELEGRAM_SMOKE_PARTNER_CHAT_ID=""
# Optional local helper inputs for `bun run telegram:save-partner-chat`.
TELEGRAM_PARTNER_CHAT_ID=""
TELEGRAM_PARTNER_ID=""
TELEGRAM_PARTNER_USERNAME=""
TELEGRAM_PARTNER_NAME=""
