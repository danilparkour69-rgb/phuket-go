# Local PostgreSQL from ../docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:54329/web_app_demo?schema=public"

# Test PostgreSQL from ../docker-compose.yml. Backend integration, Docker smoke,
# and Playwright E2E use this shape and must target the *_test database.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:54330/web_app_demo_test?schema=public"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"
