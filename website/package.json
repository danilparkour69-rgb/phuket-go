{
  "name": "@phuket-go/website",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync:media": "bun ../scripts/sync-website-media.mjs",
    "dev": "bun run sync:media && ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "bun run sync:media && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "astro": "ASTRO_TELEMETRY_DISABLED=1 astro"
  },
  "dependencies": {
    "@phuket-go/contracts": "workspace:*",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "~6.0.2",
    "vite": "^7.3.3"
  }
}
