---
const pageTitle = 'Контакты - Phuket Go'
const pageDescription =
  'Как связаться с Phuket Go по экскурсиям, заявкам, бронированию и партнёрству.'

const userContactCards = [
  {
    title: 'Email',
    text: 'Подходит для вопросов по экскурсиям, бронированию и уже отправленным заявкам.',
    actionLabel: 'Написать на email',
    href: 'mailto:phuketgoall@gmail.com',
    status: 'active',
  },
  {
    title: 'Telegram',
    text: 'Основной канал для быстрых диалогов, статусов и будущего комьюнити Phuket Go.',
    actionLabel: 'Добавим перед запуском',
    href: null,
    status: 'pending',
  },
  {
    title: 'WhatsApp / телефон',
    text: 'Нужен для срочных вопросов по выезду, трансферу и связи в день экскурсии.',
    actionLabel: 'Добавим перед запуском',
    href: null,
    status: 'pending',
  },
  {
    title: 'Max',
    text: 'Оставляем как дополнительный канал связи после подтверждения рабочих контактов.',
    actionLabel: 'Добавим перед запуском',
    href: null,
    status: 'pending',
  },
]

const partnerChecklist = [
  'Название компании или имя исполнителя',
  'Какие экскурсии или услуги вы проводите',
  'Ссылка на сайт, Telegram или другой рабочий канал',
  'Прайс, фото и описания программ',
  'Условия комиссии и способ подтверждения заявки',
]

const urgentChecklist = [
  'Имя в заявке',
  'Название экскурсии',
  'Дата поездки',
  'Телефон и удобный канал связи',
  'Район отеля или геолокация, если вопрос связан с трансфером',
]
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Phuket Go">
        <span class="brand__mark">PG</span>
        <span>Phuket Go</span>
      </a>
      <nav class="site-nav" aria-label="Основная навигация">
        <a href="/">Каталог</a>
        <a href="/faq">FAQ</a>
        <a href="/contacts" aria-current="page">Контакты</a>
      </nav>
    </header>

    <main class="contacts-page">
      <section class="contacts-hero">
        <nav class="breadcrumbs" aria-label="Хлебные крошки">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Контакты</span>
        </nav>
        <p class="eyebrow">Phuket Go</p>
        <h1>Контакты</h1>
        <p class="lead">
          Если нужно выбрать экскурсию, уточнить отправленную заявку или предложить партнёрство —
          здесь собрана вся актуальная точка входа для связи.
        </p>
      </section>

      <section class="contact-grid" aria-labelledby="contact-grid-title">
        <div class="section-heading">
          <h2 id="contact-grid-title">Как связаться сейчас</h2>
          <a href="/">Открыть каталог</a>
        </div>

        <div class="contact-card-grid">
          {userContactCards.map((card) => (
            <article class="contact-card">
              <div class="contact-card__status" data-status={card.status}>
                {card.status === 'active' ? 'Активно' : 'Добавим перед запуском'}
              </div>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              {card.href ? (
                <a class="contact-card__action" href={card.href}>{card.actionLabel}</a>
              ) : (
                <span class="contact-card__action contact-card__action--muted">{card.actionLabel}</span>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="info-grid" aria-label="Сценарии связи">
        <article class="info-card">
          <p class="eyebrow">Если вопрос срочный</p>
          <h2>Что лучше отправить сразу</h2>
          <ul>
            {urgentChecklist.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p>
            Если вопрос связан с трансфером или выездом в этот же день, эти данные помогают быстрее
            понять ситуацию без лишней переписки.
          </p>
        </article>

        <article class="info-card">
          <p class="eyebrow">Если вы партнёр</p>
          <h2>Что прислать для начала работы</h2>
          <ul>
            {partnerChecklist.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p>
            В первой версии партнёрский кабинет не нужен: заявки маршрутизируются через Telegram и
            ручное подтверждение.
          </p>
        </article>
      </section>

      <section class="cta-panel" aria-labelledby="cta-title">
        <div>
          <p class="eyebrow">Быстрый путь</p>
          <h2 id="cta-title">Проще всего начать с карточки экскурсии</h2>
          <p>
            Если вопрос касается конкретной даты, детей, района отеля или маршрута, быстрее открыть
            нужную карточку и оставить заявку прямо там.
          </p>
        </div>
        <div class="cta-panel__actions">
          <a class="cta-primary" href="/">Перейти в каталог</a>
          <a class="cta-secondary" href="mailto:phuketgoall@gmail.com">Написать на email</a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --page-bg: #f7f6f2;
    --surface: #ffffff;
    --surface-muted: #f0ede5;
    --text: #1f1f1c;
    --text-soft: #5e5a52;
    --line: rgba(31, 31, 28, 0.12);
    --accent: #1f1f1c;
    --accent-soft: #e7e2d7;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--page-bg);
    color: var(--text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 24px;
    background: color-mix(in srgb, var(--page-bg) 88%, white 12%);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
  }

  .brand__mark {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--accent);
    color: white;
    font-size: 12px;
  }

  .site-nav {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    font-size: 14px;
  }

  .site-nav a[aria-current='page'] {
    font-weight: 700;
  }

  .contacts-page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 72px;
  }

  .contacts-hero {
    padding: 10px 0 20px;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-soft);
    margin-bottom: 18px;
  }

  .eyebrow {
    margin: 0 0 8px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  h1 {
    margin: 0;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1;
  }

  .lead {
    max-width: 760px;
    margin: 18px 0 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-soft);
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 18px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 28px;
  }

  .section-heading a {
    font-size: 14px;
    color: var(--text-soft);
  }

  .contact-card-grid,
  .info-grid {
    display: grid;
    gap: 16px;
  }

  .contact-card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .info-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 40px;
  }

  .contact-card,
  .info-card,
  .cta-panel {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 20px;
  }

  .contact-card {
    padding: 22px;
  }

  .contact-card__status {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    background: var(--surface-muted);
    font-size: 12px;
    font-weight: 700;
    color: var(--text-soft);
  }

  .contact-card__status[data-status='active'] {
    background: var(--accent-soft);
    color: var(--text);
  }

  .contact-card h3,
  .info-card h2,
  .cta-panel h2 {
    margin: 14px 0 12px;
  }

  .contact-card p,
  .info-card p,
  .cta-panel p:last-child {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.65;
  }

  .contact-card__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    margin-top: 18px;
    padding: 0 16px;
    border-radius: 999px;
    background: var(--accent);
    color: white;
    font-weight: 600;
  }

  .contact-card__action--muted {
    background: var(--surface-muted);
    color: var(--text-soft);
  }

  .info-card {
    padding: 24px;
  }

  .info-card ul {
    margin: 0 0 16px;
    padding-left: 18px;
    color: var(--text-soft);
    line-height: 1.65;
  }

  .cta-panel {
    margin-top: 40px;
    padding: 28px;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
  }

  .cta-panel__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 12px;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    font-weight: 600;
  }

  .cta-primary {
    background: var(--accent);
    color: white;
  }

  .cta-secondary {
    border: 1px solid var(--line);
    background: var(--surface);
  }

  @media (max-width: 920px) {
    .contact-card-grid,
    .info-grid {
      grid-template-columns: 1fr;
    }

    .cta-panel {
      flex-direction: column;
      align-items: stretch;
    }

    .cta-panel__actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      padding: 16px;
      flex-wrap: wrap;
    }

    .contacts-page {
      width: min(100% - 24px, 1120px);
      padding-bottom: 56px;
    }

    h1 {
      font-size: 34px;
    }

    .lead {
      font-size: 16px;
    }

    .section-heading {
      flex-direction: column;
      align-items: flex-start;
    }

    .contact-card,
    .info-card,
    .cta-panel {
      border-radius: 18px;
    }

    .cta-panel {
      padding: 22px;
    }

    .cta-panel h2 {
      font-size: 24px;
    }
  }
</style>
