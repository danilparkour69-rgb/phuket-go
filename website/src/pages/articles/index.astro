---
import { loadArticles } from '../../lib/articles'

const articles = await loadArticles()
const pageTitle = 'Статьи - Phuket Go'
const pageDescription =
  'Полезные статьи Phuket Go о Пхукете, Таиланде, безопасности, выборе экскурсий и типичных вопросах туриста.'
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Phuket Go">
        <span class="brand__mark">PG</span>
        <span>Phuket Go</span>
      </a>
      <nav class="site-nav" aria-label="Основная навигация">
        <a href="/">Каталог</a>
        <a href="/articles" aria-current="page">Статьи</a>
        <a href="/faq">FAQ</a>
        <a href="/contacts">Контакты</a>
      </nav>
    </header>

    <main class="articles-page">
      <section class="articles-hero">
        <nav class="breadcrumbs" aria-label="Хлебные крошки">
          <a href="/">Главная</a>
          <span>/</span>
          <span>Статьи</span>
        </nav>
        <p class="eyebrow">Phuket Go</p>
        <h1>Статьи и путеводители</h1>
        <p class="lead">
          Материалы для тех, кто хочет не просто выбрать экскурсию, а заранее понять Пхукет,
          Таиланд и реальные нюансы отдыха.
        </p>
      </section>

      <section class="article-grid" aria-labelledby="articles-title">
        <div class="section-heading">
          <h2 id="articles-title">Что почитать перед поездкой</h2>
          <a href="/">Вернуться в каталог</a>
        </div>

        <div class="cards">
          {articles.map((article) => (
            <article class="article-card">
              <div class="article-card__meta">
                <span>{article.readTimeMinutes} мин чтения</span>
              </div>
              <h3>
                <a href={`/articles/${article.slug}`}>{article.h1}</a>
              </h3>
              <p>{article.summary}</p>
              <a class="article-card__action" href={`/articles/${article.slug}`}>Открыть статью</a>
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --page-bg: #f7f6f2;
    --surface: #ffffff;
    --surface-muted: #f0ede5;
    --text: #1f1f1c;
    --text-soft: #5e5a52;
    --line: rgba(31, 31, 28, 0.12);
    --accent: #1f1f1c;
  }

  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--page-bg);
    color: var(--text);
  }
  a { color: inherit; text-decoration: none; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 24px;
    background: color-mix(in srgb, var(--page-bg) 88%, white 12%);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; }
  .brand__mark {
    width: 34px; height: 34px; display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; background: var(--accent); color: white; font-size: 12px;
  }
  .site-nav { display: inline-flex; align-items: center; gap: 18px; font-size: 14px; }
  .site-nav a[aria-current='page'] { font-weight: 700; }

  .articles-page {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 72px;
  }
  .articles-hero { padding: 10px 0 20px; }
  .breadcrumbs {
    display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-soft); margin-bottom: 18px;
  }
  .eyebrow {
    margin: 0 0 8px; font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--text-soft);
  }
  h1 { margin: 0; font-size: clamp(34px, 5vw, 56px); line-height: 1; }
  .lead {
    max-width: 760px; margin: 18px 0 0; font-size: 18px; line-height: 1.6; color: var(--text-soft);
  }

  .section-heading {
    display: flex; align-items: end; justify-content: space-between; gap: 20px; margin-bottom: 18px;
  }
  .section-heading h2 { margin: 0; font-size: 28px; }
  .section-heading a { font-size: 14px; color: var(--text-soft); }

  .cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  .article-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 22px;
  }
  .article-card__meta span {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--text-soft);
    font-size: 12px;
    font-weight: 700;
  }
  .article-card h3 { margin: 16px 0 12px; font-size: 22px; }
  .article-card p { margin: 0; color: var(--text-soft); line-height: 1.65; }
  .article-card__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    margin-top: 18px;
    padding: 0 16px;
    border-radius: 999px;
    background: var(--accent);
    color: white;
    font-weight: 600;
  }

  @media (max-width: 920px) {
    .cards { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .site-header { padding: 16px; flex-wrap: wrap; }
    .articles-page { width: min(100% - 24px, 1120px); padding-bottom: 56px; }
    h1 { font-size: 34px; }
    .lead { font-size: 16px; }
    .section-heading { flex-direction: column; align-items: flex-start; }
  }
</style>
