---
import {
  cardImageUrls,
  categoryTitle,
  formatRub,
  formatThb,
  loadCatalog,
} from '../lib/catalog'
import { sitePath } from '../lib/paths'

const catalog = await loadCatalog()
const excursions = catalog.excursions
const totalExcursions = excursions.length

const destinationHighlights = [
  {
    title: 'Острова Пхи-Пхи',
    description: 'бирюзовые бухты, пляжи и морской день',
    query: 'phi-phi',
    matcher: (slug: string) => slug.includes('phi-phi'),
  },
  {
    title: 'Симиланские острова',
    description: 'снорклинг, белый песок и прозрачная вода',
    query: 'similany',
    matcher: (slug: string) => slug.includes('similan'),
  },
  {
    title: 'Залив Пханг Нга',
    description: 'скалы, лагуны и виды как из фильма',
    query: 'phangna',
    matcher: (slug: string) =>
      slug.includes('phang') || slug.includes('dzheyms-bond') || slug.includes('avatar'),
  },
  {
    title: 'Озеро Чеолан',
    description: 'джунгли, тишина и вода между горами',
    query: 'cheolan',
    matcher: (slug: string) => slug.includes('cheolan'),
  },
].map((destination) => ({
  ...destination,
  count: excursions.filter((excursion) => destination.matcher(excursion.slug)).length,
}))

const preferredPopularSlugs = [
  'phi-phi',
  'ranniy-phi-phi',
  'similany',
  'dzheyms-bond',
  'racha-koral',
  'cheolan-1-den',
  'polet-hanumana',
  'park-slonov',
]
const preferredPopularExcursions = preferredPopularSlugs
  .map((slug) => excursions.find((excursion) => excursion.slug === slug))
  .filter((excursion): excursion is (typeof excursions)[number] => Boolean(excursion))
const popularExcursions = [
  ...preferredPopularExcursions,
  ...excursions.filter(
    (excursion) =>
      !preferredPopularExcursions.some((popular) => popular?.slug === excursion.slug),
  ),
].slice(0, 8)

const usefulCollections = [
  {
    title: 'Морские экскурсии',
    description: 'острова, пляжи, катера и снорклинг',
    categorySlug: 'sea-tours',
  },
  {
    title: 'Активный отдых',
    description: 'рафтинг, зиплайн, квадроциклы и драйв',
    categorySlug: 'active',
  },
  {
    title: 'Шоу и вечерние программы',
    description: 'вечер без длинной дороги и раннего выезда',
    categorySlug: 'shows',
  },
  {
    title: 'Наземные маршруты',
    description: 'храмы, виды, джунгли и места силы',
    categorySlug: 'land-tours',
  },
].map((collection) => ({
  ...collection,
  count:
    catalog.status === 'ready'
      ? (catalog.categories.find((category) => category.slug === collection.categorySlug)?.count ?? 0)
      : 0,
}))
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={sitePath('/favicon.svg')} />
    <link rel="icon" href={sitePath('/favicon.ico')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Экскурсии на Пхукете - Phuket Go</title>
    <meta
      name="description"
      content="Каталог экскурсий Phuket Go: острова, шоу, активный отдых и маршруты по Пхукету с бесплатным бронированием."
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={sitePath('/')} aria-label="Phuket Go">
        <span class="brand__mark">PG</span>
        <span>Phuket Go</span>
      </a>
      <button
        class="discover-button"
        type="button"
        aria-expanded="false"
        aria-controls="discover-panel"
        data-open-panel="discover"
      >
        Направления
      </button>
      <label class="header-search">
        <span aria-hidden="true">⌕</span>
        <input
          type="search"
          value="Пхукет"
          aria-label="Поиск"
          autocomplete="off"
          data-catalog-search
        />
      </label>
      <div class="site-actions">
        <button
          class="icon-action"
          type="button"
          aria-label="Язык и валюта"
          aria-expanded="false"
          aria-controls="currency-panel"
          data-open-panel="currency"
        >
          ◎
        </button>
        <a class="icon-action" href="#catalog" aria-label="Избранное">♡</a>
        <button
          class="icon-action"
          type="button"
          aria-label="Помощь"
          aria-expanded="false"
          aria-controls="help-panel"
          data-open-panel="help"
        >
          ?
        </button>
        <a class="icon-action" href="#catalog" aria-label="Бонусы">▣</a>
        <a class="login-link" href="#catalog">Войти</a>
        <button
          class="menu-button"
          type="button"
          aria-label="Открыть меню"
          aria-expanded="false"
          aria-controls="menu-panel"
          data-open-panel="menu"
        >
          ☰
        </button>
      </div>
    </header>

    <main>
      <section class="search-bar" aria-label="Поиск по каталогу">
        <label class="search-bar__field">
          <span aria-hidden="true">⌕</span>
          <input
            type="search"
            value="Пхукет"
            aria-label="Поиск"
            autocomplete="off"
            data-catalog-search
          />
        </label>
        <button
          class="search-bar__date"
          type="button"
          aria-expanded="false"
          aria-controls="dates-panel"
          data-open-panel="dates"
          data-date-label-target
        >
          Выбрать даты
        </button>
      </section>

      <section class="page-hero" aria-labelledby="page-title">
        <nav class="breadcrumbs" aria-label="Хлебные крошки">
          <a href={sitePath('/')}>Главная</a>
          <span aria-hidden="true">/</span>
          <span>Пхукет</span>
          <span aria-hidden="true">/</span>
          <span>Экскурсии</span>
        </nav>

        <div class="page-title-row">
          <h1 id="page-title">Все экскурсии на Пхукете</h1>
          <span>{totalExcursions} направлений</span>
        </div>
      </section>

      <section class="quick-chips" aria-label="Быстрые фильтры">
        <button
          class="chip chip--date"
          type="button"
          aria-expanded="false"
          aria-controls="dates-panel"
          data-open-panel="dates"
          data-date-label-target
        >
          Выбрать даты
        </button>
        <button
          class="chip"
          type="button"
          aria-expanded="false"
          aria-controls="travelers-panel"
          data-open-panel="travelers"
          data-travelers-label-target
        >
          2 взрослых
        </button>
        <button
          class="chip"
          type="button"
          aria-expanded="false"
          aria-controls="filters-panel"
          data-open-filters
          data-open-panel="filters"
        >
          Фильтры
        </button>
        <button class="chip chip--active" type="button" data-category-filter-mobile="all">Все</button>
        {catalog.status === 'ready' ? catalog.categories.slice(0, 5).map((category) => (
          <button class="chip" type="button" data-category-filter-mobile={category.slug}>
            {category.title}
          </button>
        )) : null}
      </section>

      <section class="marketplace" id="catalog" aria-labelledby="catalog-title">
        {
          catalog.status === 'error' ? (
            <div class="notice">
              <strong>Каталог пока не загрузился.</strong>
              <span>Проверьте, что backend запущен на {catalog.apiUrl}.</span>
            </div>
          ) : (
            <>
              <aside class="sidebar" id="filters" aria-label="Фильтры каталога">
                <div class="filter-panel">
                  <div class="filter-panel__heading">
                    <strong>Фильтры</strong>
                    <button type="button" data-clear-filters>Сбросить</button>
                  </div>

                  <div class="filter-group">
                    <p>Категории</p>
                    <button class="category-option category-option--active" type="button" data-category-filter="all">
                      <span>Все экскурсии</span>
                      <span>{totalExcursions}</span>
                    </button>
                    {catalog.categories.map((category) => (
                      <button class="category-option" type="button" data-category-filter={category.slug}>
                        <span>{category.title}</span>
                        <span>{category.count}</span>
                      </button>
                    ))}
                  </div>

                  <div class="filter-group">
                    <p>Особенности</p>
                    <span class="check-row">Русский гид</span>
                    <span class="check-row">Бесплатное бронирование</span>
                    <span class="check-row">Связь после заявки</span>
                  </div>
                </div>
              </aside>

              <div class="results">
                <h2 class="visually-hidden" id="catalog-title">Каталог экскурсий</h2>
                <div class="results__topline">
                  <p><span data-results-count>{totalExcursions}</span> вариантов</p>
                  <label class="sort-control">
                    <span>Сортировать:</span>
                    <select aria-label="Сортировать" data-sort-select>
                      <option value="recommended">Рекомендуем</option>
                      <option value="price-asc">Сначала дешевле</option>
                      <option value="price-desc">Сначала дороже</option>
                    </select>
                  </label>
                </div>

                <div class="result-list" data-result-list>
                  {excursions.map((excursion, index) => {
                    const imageUrls = cardImageUrls(excursion, catalog.apiUrl)
                    const visibleDotCount = Math.min(imageUrls.length, 7)

                    return (
                      <article
                        class="result-card"
                        data-card
                        data-category={excursion.categorySlug}
                        data-price={excursion.priceFromThb}
                        data-order={index}
                        data-search={`${excursion.slug} ${excursion.title} ${excursion.shortEmotion} ${categoryTitle(excursion.categorySlug)}`.toLowerCase()}
                      >
                        <div class="result-card__media" data-card-carousel>
                          <a class="result-card__image-link" href={sitePath(`/excursions/${excursion.slug}`)} aria-label={`Открыть ${excursion.title}`}>
                            {imageUrls.length ? (
                              imageUrls.map((imageUrl, imageIndex) => (
                                <img
                                  src={imageIndex === 0 ? imageUrl : undefined}
                                  data-carousel-src={imageUrl}
                                  alt=""
                                  loading={index < 4 && imageIndex === 0 ? 'eager' : 'lazy'}
                                  data-carousel-image
                                  data-active={imageIndex === 0 ? 'true' : 'false'}
                                />
                              ))
                            ) : (
                              <span class="result-card__placeholder"></span>
                            )}
                          </a>
                          <button class="favorite-button favorite-button--media" type="button" aria-label={`Добавить в избранное: ${excursion.title}`} aria-pressed="false" data-favorite-button>
                            ♡
                          </button>
                          {imageUrls.length > 1 ? (
                            <>
                              <button
                                class="carousel-arrow carousel-arrow--prev"
                                type="button"
                                aria-label={`Предыдущее фото: ${excursion.title}`}
                                data-carousel-prev
                              >
                                ‹
                              </button>
                              <button
                                class="carousel-arrow carousel-arrow--next"
                                type="button"
                                aria-label={`Следующее фото: ${excursion.title}`}
                                data-carousel-next
                              >
                                ›
                              </button>
                              <span class="media-dots" aria-label={`Фотографии экскурсии: ${imageUrls.length}`} data-carousel-dots>
                                {Array.from({ length: visibleDotCount }, (_, dotIndex) => (
                                  <button
                                    type="button"
                                    aria-label={`Показать фото ${dotIndex + 1}`}
                                    aria-current={dotIndex === 0 ? 'true' : 'false'}
                                    data-carousel-dot
                                    data-dot-index={dotIndex}
                                  ></button>
                                ))}
                              </span>
                            </>
                          ) : null}
                        </div>

                        <div class="result-card__content">
                          <div class="result-card__head">
                            <a href={sitePath(`/excursions/${excursion.slug}`)}>{excursion.title}</a>
                          </div>
                          <div class="rating-row" aria-label={excursion.externalRating?.score ? `Рейтинг ${excursion.externalRating.score}` : 'Рейтинг TripAdvisor уточняется'}>
                            <span class="rating-bubbles" aria-hidden="true">●●●●●</span>
                            {excursion.externalRating?.score ? (
                              <>
                                <strong>{excursion.externalRating.score.toFixed(1)}</strong>
                                {excursion.externalRating.reviewCount ? (
                                  <span>({excursion.externalRating.reviewCount} отзывов)</span>
                                ) : null}
                                <span>{excursion.externalRating.label}</span>
                              </>
                            ) : (
                              <span>TripAdvisor: проверяем рейтинг</span>
                            )}
                          </div>
                          <p class="result-card__summary">{excursion.shortEmotion}</p>
                          <div class="card-meta-list" aria-label="Ключевые условия">
                            <span>{excursion.duration ?? 'Длительность уточняется'}</span>
                            <span>Русский гид</span>
                            <span>Бесплатная бронь</span>
                          </div>
                        </div>

                        <div class="result-card__aside">
                          <span class="card-rating">★ Русский гид</span>
                          <span class="price-kicker">от</span>
                          <strong>{formatThb(excursion.priceFromThb)}</strong>
                          <span>≈ {formatRub(excursion.priceFromRub)}</span>
                          <a href={sitePath(`/excursions/${excursion.slug}`)}>Проверить доступность</a>
                        </div>
                      </article>
                    )
                  })}
                </div>

                <p class="empty-state" hidden data-empty-state>По такому запросу пока ничего не найдено.</p>
              </div>
            </>
          )
        }
      </section>

      <section class="catalog-followups" id="followups" aria-label="Дополнительные подборки">
        <div class="followup-block">
          <div class="followup-heading">
            <h2>Популярные направления рядом с Пхукетом</h2>
            <a href="#catalog">Смотреть все</a>
          </div>
          <div class="place-strip">
            {destinationHighlights.map((destination) => (
              <a class="place-card" href={`#catalog`} data-followup-search={destination.query}>
                <span>{destination.title}</span>
                <small>{destination.description}</small>
                <em>{destination.count} вариантов</em>
              </a>
            ))}
          </div>
        </div>

        <div class="followup-block">
          <div class="followup-heading">
            <h2>Популярные экскурсии</h2>
            <a href="#catalog">Все варианты</a>
          </div>
          <div class="popular-tour-grid">
            {popularExcursions.map((excursion) => (
              <a class="compact-tour-card" href={sitePath(`/excursions/${excursion.slug}`)}>
                <span>{excursion.title}</span>
                <small>
                  {excursion.duration ?? 'Длительность уточняется'} · от {formatThb(excursion.priceFromThb)}
                </small>
              </a>
            ))}
          </div>
        </div>

        <div class="followup-block">
          <div class="followup-heading">
            <h2>Что ещё часто выбирают</h2>
          </div>
          <div class="collection-grid">
            {usefulCollections.map((collection) => (
              <a class="collection-card" href="#catalog" data-followup-category={collection.categorySlug}>
                <span>{collection.title}</span>
                <small>{collection.description}</small>
                <em>{collection.count} вариантов</em>
              </a>
            ))}
          </div>
        </div>
      </section>

      <div class="panel-overlay" hidden data-panel-overlay></div>

      <section
        class="utility-panel utility-panel--popover"
        id="discover-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="discover-panel-title"
        data-panel="discover"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="discover-panel-title">Направления</strong>
            <span>Быстрый вход в самые востребованные маршруты.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <div class="panel-spotlight-grid">
          {destinationHighlights.map((destination) => (
            <button class="panel-spotlight" type="button" data-panel-search={destination.query}>
              <span>{destination.title}</span>
              <small>{destination.description}</small>
              <em>{destination.count} вариантов</em>
            </button>
          ))}
        </div>
      </section>

      <section
        class="utility-panel utility-panel--popover"
        id="currency-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="currency-panel-title"
        data-panel="currency"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="currency-panel-title">Язык и цены</strong>
            <span>Текущий режим каталога Phuket Go.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <div class="panel-note-list">
          <div class="panel-note">
            <strong>Язык интерфейса</strong>
            <span>Русский</span>
          </div>
          <div class="panel-note">
            <strong>Основная цена</strong>
            <span>В батах THB</span>
          </div>
          <div class="panel-note">
            <strong>Ориентир</strong>
            <span>Рубли показываем рядом как удобный расчет</span>
          </div>
        </div>
      </section>

      <section
        class="utility-panel utility-panel--popover"
        id="help-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="help-panel-title"
        data-panel="help"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="help-panel-title">Как это работает</strong>
            <span>Коротко о бронировании и подборе экскурсии.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <div class="panel-note-list">
          <div class="panel-note">
            <strong>Бесплатная бронь</strong>
            <span>Оставляете заявку без оплаты, потом уточняете детали.</span>
          </div>
          <div class="panel-note">
            <strong>Русский гид</strong>
            <span>Во всех карточках Phuket Go показываем программы с русским гидом.</span>
          </div>
          <div class="panel-note">
            <strong>Что выбрать</strong>
            <span>Сначала направление, потом уже конкретную программу внутри него.</span>
          </div>
        </div>
        <a class="panel-anchor" href="#catalog" data-close-panel-link>
          Перейти к каталогу
        </a>
      </section>

      <section
        class="utility-panel utility-panel--drawer"
        id="menu-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="menu-panel-title"
        data-panel="menu"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="menu-panel-title">Меню</strong>
            <span>Основные разделы страницы.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <nav class="menu-link-list" aria-label="Разделы">
          <a href="#catalog" data-close-panel-link>Каталог экскурсий</a>
          <a href={sitePath('/articles')} data-close-panel-link>Статьи</a>
          <a href={sitePath('/faq')} data-close-panel-link>FAQ</a>
          <a href={sitePath('/contacts')} data-close-panel-link>Контакты</a>
          <a href={sitePath('/booking-terms')} data-close-panel-link>Условия бронирования</a>
          <a href="#followups" data-close-panel-link>Популярные подборки</a>
          <a href="#catalog" data-panel-search="phi-phi">Острова Пхи-Пхи</a>
          <a href="#catalog" data-panel-search="similany">Симиланы</a>
          <a href="#catalog" data-panel-search="phangna">Пханг Нга и Джеймс Бонд</a>
        </nav>
      </section>

      <section
        class="utility-panel utility-panel--drawer"
        id="filters-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="filters-panel-title"
        data-panel="filters"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="filters-panel-title">Фильтры</strong>
            <span>Сужаем каталог по типу впечатления.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <div class="panel-section">
          <strong>Категории</strong>
          <div class="panel-category-list">
            <button
              class="category-option category-option--active"
              type="button"
              data-panel-category="all"
            >
              <span>Все экскурсии</span>
              <span>{totalExcursions}</span>
            </button>
            {catalog.status === 'ready' ? catalog.categories.map((category) => (
              <button class="category-option" type="button" data-panel-category={category.slug}>
                <span>{category.title}</span>
                <span>{category.count}</span>
              </button>
            )) : null}
          </div>
        </div>
        <div class="panel-section">
          <strong>Подсказка</strong>
          <div class="panel-note-list">
            <div class="panel-note">
              <strong>Русский гид</strong>
              <span>Это базовое правило для карточек MVP.</span>
            </div>
            <div class="panel-note">
              <strong>Бесплатная бронь</strong>
              <span>Оставляете запрос, а детали подтверждаются позже.</span>
            </div>
          </div>
        </div>
        <div class="panel-actions">
          <button class="panel-secondary" type="button" data-panel-clear-filters>Сбросить</button>
          <button class="panel-primary" type="button" data-close-panel>Готово</button>
        </div>
      </section>

      <section
        class="utility-panel utility-panel--dialog"
        id="dates-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="dates-panel-title"
        data-panel="dates"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="dates-panel-title">Выбрать даты</strong>
            <span>Нужные даты сохраняем для запроса менеджеру.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <div class="panel-date-grid">
          <label class="panel-field">
            <span>С</span>
            <input type="date" data-date-start />
          </label>
          <label class="panel-field">
            <span>По</span>
            <input type="date" data-date-end />
          </label>
        </div>
        <div class="panel-actions">
          <button class="panel-secondary" type="button" data-clear-dates>Сбросить</button>
          <button class="panel-primary" type="button" data-apply-dates>Применить</button>
        </div>
      </section>

      <section
        class="utility-panel utility-panel--dialog"
        id="travelers-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="travelers-panel-title"
        data-panel="travelers"
        hidden
        tabindex="-1"
      >
        <div class="utility-panel__head">
          <div>
            <strong id="travelers-panel-title">Сколько человек</strong>
            <span>Количество сохраняем для заявки и подбора цены.</span>
          </div>
          <button class="panel-close" type="button" aria-label="Закрыть" data-close-panel>×</button>
        </div>
        <div class="traveler-stepper">
          <button type="button" aria-label="Уменьшить количество" data-travelers-dec>−</button>
          <strong data-travelers-count>2</strong>
          <button type="button" aria-label="Увеличить количество" data-travelers-inc>+</button>
        </div>
        <div class="panel-actions">
          <button class="panel-secondary" type="button" data-reset-travelers>Сбросить</button>
          <button class="panel-primary" type="button" data-close-panel>Готово</button>
        </div>
      </section>

    </main>

    <script>
      const searchInputs = [...document.querySelectorAll<HTMLInputElement>('[data-catalog-search]')]
      const resultList = document.querySelector<HTMLElement>('[data-result-list]')
      const cards = [...document.querySelectorAll<HTMLElement>('[data-card]')]
      const sidebarButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-category-filter]')]
      const mobileButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-category-filter-mobile]')]
      const panelCategoryButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-panel-category]')]
      const resultsCount = document.querySelector<HTMLElement>('[data-results-count]')
      const emptyState = document.querySelector<HTMLElement>('[data-empty-state]')
      const sortSelect = document.querySelector<HTMLSelectElement>('[data-sort-select]')
      const clearFiltersButton = document.querySelector<HTMLButtonElement>('[data-clear-filters]')
      const followupSearchLinks = [...document.querySelectorAll<HTMLElement>('[data-followup-search]')]
      const followupCategoryLinks = [...document.querySelectorAll<HTMLElement>('[data-followup-category]')]
      const panelOverlay = document.querySelector<HTMLElement>('[data-panel-overlay]')
      const panelTriggers = [...document.querySelectorAll<HTMLButtonElement>('[data-open-panel]')]
      const panels = [...document.querySelectorAll<HTMLElement>('[data-panel]')]
      const closePanelButtons = [...document.querySelectorAll<HTMLElement>('[data-close-panel]')]
      const closePanelLinks = [...document.querySelectorAll<HTMLAnchorElement>('[data-close-panel-link]')]
      const panelSearchLinks = [...document.querySelectorAll<HTMLElement>('[data-panel-search]')]
      const panelClearFiltersButton = document.querySelector<HTMLButtonElement>('[data-panel-clear-filters]')
      const dateLabelTargets = [...document.querySelectorAll<HTMLElement>('[data-date-label-target]')]
      const travelersLabelTargets = [...document.querySelectorAll<HTMLElement>('[data-travelers-label-target]')]
      const dateStartInput = document.querySelector<HTMLInputElement>('[data-date-start]')
      const dateEndInput = document.querySelector<HTMLInputElement>('[data-date-end]')
      const clearDatesButton = document.querySelector<HTMLButtonElement>('[data-clear-dates]')
      const applyDatesButton = document.querySelector<HTMLButtonElement>('[data-apply-dates]')
      const travelersCountNode = document.querySelector<HTMLElement>('[data-travelers-count]')
      const travelersDecreaseButton = document.querySelector<HTMLButtonElement>('[data-travelers-dec]')
      const travelersIncreaseButton = document.querySelector<HTMLButtonElement>('[data-travelers-inc]')
      const resetTravelersButton = document.querySelector<HTMLButtonElement>('[data-reset-travelers]')
      let activeCategory = 'all'
      let openPanelName = ''
      let travelersCount = 2

      const shortDateFormatter = new Intl.DateTimeFormat('ru-RU', {
        day: 'numeric',
        month: 'short',
      })

      function formatTravelersLabel(count: number) {
        const peopleLabel = count === 1 ? 'взрослый' : count < 5 ? 'взрослых' : 'взрослых'
        return `${count} ${peopleLabel}`
      }

      function syncTravelerLabels() {
        const label = formatTravelersLabel(travelersCount)
        travelersLabelTargets.forEach((target) => {
          target.textContent = label
        })
        if (travelersCountNode) travelersCountNode.textContent = String(travelersCount)
      }

      function formatDateLabel() {
        const startValue = dateStartInput?.value ?? ''
        const endValue = dateEndInput?.value ?? ''
        if (!startValue && !endValue) return 'Выбрать даты'

        if (startValue && endValue) {
          return `${shortDateFormatter.format(new Date(startValue))} - ${shortDateFormatter.format(new Date(endValue))}`
        }

        const onlyDate = startValue || endValue
        return shortDateFormatter.format(new Date(onlyDate))
      }

      function syncDateLabels() {
        const label = formatDateLabel()
        dateLabelTargets.forEach((target) => {
          target.textContent = label
        })
      }

      function closePanels() {
        openPanelName = ''
        document.body.classList.remove('panel-open')
        panelOverlay?.setAttribute('hidden', '')
        panels.forEach((panel) => {
          panel.setAttribute('hidden', '')
        })
        panelTriggers.forEach((trigger) => {
          trigger.setAttribute('aria-expanded', 'false')
        })
      }

      function openPanel(name: string) {
        openPanelName = name
        document.body.classList.add('panel-open')
        panelOverlay?.removeAttribute('hidden')

        panels.forEach((panel) => {
          if (panel.dataset.panel === name) {
            panel.removeAttribute('hidden')
            window.requestAnimationFrame(() => panel.focus())
          } else {
            panel.setAttribute('hidden', '')
          }
        })

        panelTriggers.forEach((trigger) => {
          const isActive = trigger.dataset.openPanel === name
          trigger.setAttribute('aria-expanded', String(isActive))
        })
      }

      function togglePanel(name: string) {
        if (openPanelName === name) {
          closePanels()
          return
        }
        openPanel(name)
      }

      function applySearchQuery(query: string) {
        searchInputs.forEach((input) => {
          input.value = query || 'Пхукет'
        })
        setActiveCategory('all')
        resultList?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }

      document.querySelectorAll<HTMLButtonElement>('[data-favorite-button]').forEach((button) => {
        button.addEventListener('click', () => {
          const isPressed = button.getAttribute('aria-pressed') === 'true'
          button.setAttribute('aria-pressed', String(!isPressed))
        })
      })

      document.querySelectorAll<HTMLElement>('[data-card-carousel]').forEach((carousel) => {
        const images = [...carousel.querySelectorAll<HTMLImageElement>('[data-carousel-image]')]
        const dots = [...carousel.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]')]
        const previousButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]')
        const nextButton = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]')
        let activeIndex = 0
        let touchStartX: number | null = null

        function setActiveImage(nextIndex: number) {
          if (images.length === 0) return
          activeIndex = (nextIndex + images.length) % images.length

          images.forEach((image, imageIndex) => {
            if (imageIndex === activeIndex && !image.getAttribute('src')) {
              image.setAttribute('src', image.dataset.carouselSrc ?? '')
            }
            image.dataset.active = imageIndex === activeIndex ? 'true' : 'false'
          })

          const activeDotIndex = Math.min(activeIndex, Math.max(dots.length - 1, 0))
          dots.forEach((dot, dotIndex) => {
            dot.setAttribute('aria-current', dotIndex === activeDotIndex ? 'true' : 'false')
          })
        }

        function moveCarousel(delta: number, event?: Event) {
          event?.preventDefault()
          event?.stopPropagation()
          setActiveImage(activeIndex + delta)
        }

        previousButton?.addEventListener('click', (event) => moveCarousel(-1, event))
        nextButton?.addEventListener('click', (event) => moveCarousel(1, event))

        dots.forEach((dot) => {
          dot.addEventListener('click', (event) => {
            event.preventDefault()
            event.stopPropagation()
            setActiveImage(Number(dot.dataset.dotIndex ?? 0))
          })
        })

        carousel.addEventListener('touchstart', (event) => {
          touchStartX = event.changedTouches[0]?.clientX ?? null
        }, { passive: true })

        carousel.addEventListener('touchend', (event) => {
          if (touchStartX === null) return
          const touchEndX = event.changedTouches[0]?.clientX ?? touchStartX
          const deltaX = touchEndX - touchStartX
          touchStartX = null

          if (Math.abs(deltaX) < 40) return
          moveCarousel(deltaX < 0 ? 1 : -1, event)
        })
      })

      function setActiveCategory(category: string) {
        activeCategory = category
        sidebarButtons.forEach((button) => {
          button.classList.toggle('category-option--active', button.dataset.categoryFilter === category)
        })
        panelCategoryButtons.forEach((button) => {
          button.classList.toggle('category-option--active', button.dataset.panelCategory === category)
        })
        mobileButtons.forEach((button) => {
          const isActive = button.dataset.categoryFilterMobile === category
          button.classList.toggle('pill--active', isActive)
          button.classList.toggle('chip--active', isActive)
        })
        updateCatalog()
      }

      function sortCards() {
        if (!resultList) return
        const mode = sortSelect?.value ?? 'recommended'
        const sortedCards = [...cards].sort((left, right) => {
          if (mode === 'price-asc') {
            return Number(left.dataset.price ?? 0) - Number(right.dataset.price ?? 0)
          }
          if (mode === 'price-desc') {
            return Number(right.dataset.price ?? 0) - Number(left.dataset.price ?? 0)
          }
          return Number(left.dataset.order ?? 0) - Number(right.dataset.order ?? 0)
        })
        sortedCards.forEach((card) => resultList.append(card))
      }

      function updateCatalog() {
        const rawQuery =
          searchInputs.find((input) => input.value.trim())?.value.trim().toLowerCase() ?? ''
        const query = rawQuery === 'пхукет' ? '' : rawQuery
        let visibleCount = 0

        cards.forEach((card) => {
          const category = card.dataset.category ?? ''
          const searchableText = card.dataset.search ?? ''
          const matchesCategory = activeCategory === 'all' || category === activeCategory
          const matchesSearch = query === '' || searchableText.includes(query)
          const isVisible = matchesCategory && matchesSearch
          card.hidden = !isVisible
          if (isVisible) visibleCount += 1
        })

        if (resultsCount) resultsCount.textContent = String(visibleCount)
        if (emptyState) emptyState.hidden = visibleCount !== 0
      }

      sidebarButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setActiveCategory(button.dataset.categoryFilter ?? 'all')
        })
      })

      mobileButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setActiveCategory(button.dataset.categoryFilterMobile ?? 'all')
        })
      })

      followupSearchLinks.forEach((link) => {
        link.addEventListener('click', () => {
          const query = link.dataset.followupSearch ?? ''
          applySearchQuery(query)
        })
      })

      followupCategoryLinks.forEach((link) => {
        link.addEventListener('click', () => {
          searchInputs.forEach((input) => {
            input.value = 'Пхукет'
          })
          setActiveCategory(link.dataset.followupCategory ?? 'all')
        })
      })

      panelSearchLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          event.preventDefault()
          const query = link.dataset.panelSearch ?? ''
          applySearchQuery(query)
          closePanels()
        })
      })

      panelCategoryButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setActiveCategory(button.dataset.panelCategory ?? 'all')
          closePanels()
          resultList?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      })

      searchInputs.forEach((input) => {
        input.addEventListener('input', () => {
          searchInputs.forEach((otherInput) => {
            if (otherInput !== input) otherInput.value = input.value
          })
          updateCatalog()
        })
      })
      sortSelect?.addEventListener('change', () => {
        sortCards()
        updateCatalog()
      })
      clearFiltersButton?.addEventListener('click', () => {
        searchInputs.forEach((input) => {
          input.value = 'Пхукет'
        })
        setActiveCategory('all')
      })

      panelClearFiltersButton?.addEventListener('click', () => {
        searchInputs.forEach((input) => {
          input.value = 'Пхукет'
        })
        setActiveCategory('all')
        closePanels()
      })

      panelTriggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const panelName = trigger.dataset.openPanel
          if (!panelName) return
          togglePanel(panelName)
        })
      })

      closePanelButtons.forEach((button) => {
        button.addEventListener('click', closePanels)
      })

      closePanelLinks.forEach((link) => {
        link.addEventListener('click', () => {
          closePanels()
        })
      })

      panelOverlay?.addEventListener('click', closePanels)

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && openPanelName) closePanels()
      })

      travelersDecreaseButton?.addEventListener('click', () => {
        travelersCount = Math.max(1, travelersCount - 1)
        syncTravelerLabels()
      })

      travelersIncreaseButton?.addEventListener('click', () => {
        travelersCount = Math.min(12, travelersCount + 1)
        syncTravelerLabels()
      })

      resetTravelersButton?.addEventListener('click', () => {
        travelersCount = 2
        syncTravelerLabels()
      })

      clearDatesButton?.addEventListener('click', () => {
        if (dateStartInput) dateStartInput.value = ''
        if (dateEndInput) dateEndInput.value = ''
        syncDateLabels()
      })

      applyDatesButton?.addEventListener('click', () => {
        syncDateLabels()
        closePanels()
      })

      dateStartInput?.addEventListener('change', syncDateLabels)
      dateEndInput?.addEventListener('change', syncDateLabels)

      syncTravelerLabels()
      syncDateLabels()
    </script>
  </body>
</html>

