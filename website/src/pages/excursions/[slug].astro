          </section>

          <section class="traveler-love" aria-labelledby="traveler-love-title">
            <div class="traveler-love__heading">
              <h2 id="traveler-love-title">Почему путешественникам нравится</h2>
              <a href="#reviews">
                {hasTrustSummary ? `${formattedTrustRating} · ${formattedReviewCount} отзывов` : 'Отзывы скоро'}
              </a>
            </div>
            <div class="traveler-love__chips" aria-label="Темы отзывов">
              {travelerLoveTags.map((tag, index) => (
                <button
                  class:list={['traveler-love__chip', index === 0 && 'traveler-love__chip--active']}
                  type="button"
                >
                  {tag}
                </button>
              ))}
            </div>
            <div class="traveler-love__cards">
