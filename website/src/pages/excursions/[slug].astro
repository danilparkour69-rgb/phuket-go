              </button>
              <button
                class="gallery-arrow gallery-arrow--right"
                type="button"
                aria-label="Следующее фото"
                id="gallery-arrow-next"
                data-gallery-action="next"
              >
                <span class="gallery-arrow__glyph" aria-hidden="true">›</span>
              </button>
              <div class="gallery-dots" aria-label="Слайд индикаторы">
                {images.slice(0, 8).map((_image, index) => (
                  <button
                    class:list={['gallery-dot', index === 0 && 'gallery-dot--active']}
                    type="button"
                    data-gallery-dot={index}
                    aria-label={`Перейти к фото ${index + 1}`}
                  ></button>
                ))}
              </div>
            </figure>
          </section>

          <section class="quick-facts" aria-label="Коротко об экскурсии">
            {quickFacts.map((item) => (
              <div class="quick-fact">
                <span></span>
                <strong>{item.value}</strong>
                <small>{item.label}</small>
