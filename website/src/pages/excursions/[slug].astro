        <section class="discovery-block" aria-labelledby="recently-viewed-title">
          <div class="discovery-block__heading">
            <h2 id="recently-viewed-title">Вы недавно смотрели</h2>
          </div>
          <div class="experience-carousel" data-carousel>
            <div class="experience-carousel__meta" data-carousel-meta>
              <span class="experience-carousel__count">
                <span data-carousel-page>1</span>
                <span>/</span>
                <span data-carousel-pages>1</span>
              </span>
              <div class="experience-carousel__controls">
                <button type="button" class="experience-carousel__control" data-carousel-prev aria-label="Предыдущие просмотренные">
                  ‹
                </button>
                <button type="button" class="experience-carousel__control" data-carousel-next aria-label="Следующие просмотренные">
                  ›
                </button>
              </div>
            </div>
            <div class="experience-carousel__viewport" data-carousel-viewport>
              <div class="recently-viewed-grid experience-carousel__track" data-carousel-track>
            {recentlyViewedCards.map((item) => (
              <a class="experience-card experience-card--compact" href={`/excursions/${item.slug}`}>
                <div class="experience-card__media">
                  <span class="experience-card__favorite" aria-hidden="true">♡</span>
                  {item.imageUrl ? (
                    <img src={item.imageUrl} alt={item.title} loading="lazy" />
                  ) : (
                    <span class="experience-card__placeholder">Фото готовятся</span>
                  )}
                </div>
                <div class="experience-card__body">
                  <small>{discoveryLocationLabel(item.categorySlug)}</small>
                  <strong>{item.title}</strong>
                  <div class="experience-card__rating">
                    <span class="experience-card__stars" aria-hidden="true">
                      {ratingStars(item.externalRating?.score ?? 5)}
                    </span>
                    <span>
                      {item.externalRating?.reviewCount
                        ? `${item.externalRating.reviewCount} отзывов`
                        : 'Отзывы скоро'}
                    </span>
                  </div>
                  <div class="experience-card__facts">
                    <span>Русский гид</span>
                  </div>
                  <div class="experience-card__price">
                    <span>от {formatThb(item.priceFromThb)}</span>
                    <small>≈ {formatRub(item.priceFromRub)}</small>
                  </div>
                </div>
              </a>
            ))}
              </div>
            </div>
          </div>
        </section>
      </section>

      <nav class="section-anchor-bar" id="section-anchor-bar" aria-label="Навигация по разделам">
        <div class="section-anchor-bar__inner">
          {sectionNavItems.map((item) => (
            <a
              class="section-anchor-bar__item"
              href={item.href}
              data-section-nav={item.key}
              data-section-target={item.targetId}
            >
              {item.label}
            </a>
          ))}
        </div>
      </nav>

      <nav class="bottom-funnel-menu" aria-label="Блоки внизу страницы">
        {bottomMenuItems.map((item) => (
          <a
            class:list={[
              'bottom-funnel-menu__item',
              item.action && item.action === 'booking' && 'bottom-funnel-menu__item--primary',
            ]}
            href={item.href}
            data-booking-action={item.action}
            data-bottom-nav={item.key}
            data-bottom-target={item.targetId}
            aria-label={`Блок «${item.label.toLowerCase()}»`}
          >
            <span class="bottom-funnel-menu__icon" aria-hidden="true">
              <span set:html={menuIcon(item.icon)} />
            </span>
            <strong>{item.label}</strong>
            <span>{item.description}</span>
          </a>
        ))}
      </nav>

      {mainImage ? (
        <div class="gallery-modal" id="gallery-modal" hidden>
          <div class="gallery-modal__backdrop" data-gallery-modal-close></div>
          <div class="gallery-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="gallery-modal-title">
            <button type="button" class="gallery-modal__close" data-gallery-modal-close aria-label="Закрыть галерею">
              ×
            </button>
            <div class="gallery-modal__top">
              <strong id="gallery-modal-title">{excursion.title}</strong>
              <span data-gallery-modal-counter>1 / {images.length}</span>
            </div>
            <div class="gallery-modal__stage">
              <button type="button" class="gallery-modal__arrow gallery-modal__arrow--left" data-gallery-modal-prev aria-label="Предыдущее фото">
                ‹
              </button>
              <img
                id="gallery-modal-image"
                src={mainImage.absoluteUrl}
                alt={mainImage.alt ?? excursion.title}
              />
              <button type="button" class="gallery-modal__arrow gallery-modal__arrow--right" data-gallery-modal-next aria-label="Следующее фото">
                ›
              </button>
            </div>
            <div class="gallery-modal__thumbs" aria-label="Миниатюры галереи">
              {images.map((image, index) => (
                <button
                  type="button"
                  class:list={['gallery-modal__thumb', index === 0 && 'gallery-modal__thumb--active']}
                  data-gallery-modal-thumb={index}
                  aria-label={`Фото ${index + 1}`}
                >
                  <img src={image.absoluteUrl} alt={image.alt ?? excursion.title} loading="lazy" />
                </button>
              ))}
            </div>
          </div>
        </div>
      ) : null}
    </main>

    <footer class="site-footer">
      <div class="site-footer__socials" aria-label="Социальные сети">
        <a href="/" aria-label="Facebook">f</a>
        <a href="/" aria-label="X">x</a>
        <a href="/" aria-label="Pinterest">p</a>
        <a href="/" aria-label="Instagram">ig</a>
        <a href="/" aria-label="YouTube">yt</a>
        <a href="/" aria-label="TikTok">tt</a>
      </div>
      <div class="site-footer__grid">
        {footerColumns.map((column) => (
          <div class="site-footer__column">
            <strong>{column.title}</strong>
            <div class="site-footer__links">
              {column.links.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="site-footer__bottom">
        <div class="site-footer__apps">
          <a href="/">Google Play</a>
          <a href="/">App Store</a>
        </div>
        <small>© 2026 Phuket Go. Каталог экскурсий и бронирование через менеджера.</small>
      </div>
    </footer>

    <script is:inline>
      function safeText(value) {
        if (value === null || value === undefined) return ''
        return String(value)
      }

      var galleryDataElement = document.getElementById('gallery-data')
      var galleryData = []
      if (galleryDataElement && galleryDataElement.textContent) {
        try {
          var parsed = JSON.parse(galleryDataElement.textContent)
          if (Array.isArray(parsed)) galleryData = parsed
        } catch (error) {
          galleryData = []
          console.error('gallery-data parse error', error)
        }
      }

      var galleryMainImage = document.getElementById('gallery-main-image')
      var galleryRoot = document.querySelector('.viator-gallery')
      var galleryMain = document.querySelector('.gallery-main')
      var galleryThumbs = Array.from(document.querySelectorAll('[data-gallery-thumb-index]'))
      var galleryDots = Array.from(document.querySelectorAll('[data-gallery-dot]'))
      var galleryOpenTriggers = Array.from(document.querySelectorAll('[data-gallery-open]'))
      var galleryModal = document.getElementById('gallery-modal')
      var galleryModalImage = document.getElementById('gallery-modal-image')
      var galleryModalCounter = document.querySelector('[data-gallery-modal-counter]')
      var galleryModalCloseButtons = Array.from(document.querySelectorAll('[data-gallery-modal-close]'))
      var galleryModalThumbs = Array.from(document.querySelectorAll('[data-gallery-modal-thumb]'))
      var galleryModalPrev = document.querySelector('[data-gallery-modal-prev]')
      var galleryModalNext = document.querySelector('[data-gallery-modal-next]')
      var leadForm = document.getElementById('lead-form')
      var leadFormResult = document.getElementById('lead-form-result')
      var shareButton = document.querySelector('[data-share-button]')
      var favoriteToggle = document.querySelector('[data-favorite-toggle]')
      var bookingSelectorButtons = Array.from(document.querySelectorAll('[data-booking-selector]'))
      var bookingDateSummary = document.querySelector('[data-booking-selector-value=\"date\"]')
      var bookingGuestSummary = document.querySelector('[data-booking-selector-value=\"guests\"]')
      var siteHeader = document.querySelector('.site-header')
      var sectionAnchorBar = document.getElementById('section-anchor-bar')
      var bottomFunnelMenu = document.querySelector('.bottom-funnel-menu')
      var sectionOverview = document.getElementById('section-overview')
      var reviewFeed = document.querySelector('[data-review-feed]')
      var reviewCards = Array.from(document.querySelectorAll('[data-review-card]'))
      var reviewFilterButtons = Array.from(document.querySelectorAll('[data-review-filter]'))
      var reviewSearch = document.querySelector('[data-review-search]')
      var reviewSort = document.querySelector('[data-review-sort]')
      var reviewEmpty = document.querySelector('[data-review-empty]')
      var reviewShowMore = document.querySelector('[data-review-show-more]')
      var discoveryCarousels = Array.from(document.querySelectorAll('[data-carousel]'))
      var activeGalleryIndex = 0
      var isGalleryModalOpen = false
      var galleryTouchStartX = null
      var galleryTouchStartY = null

      function normalizeGalleryIndex(value, fallback) {
        var parsed = Number.parseInt(value, 10)
        if (!Number.isFinite(parsed)) return fallback
        if (!galleryData.length) return fallback
        var maxIndex = galleryData.length - 1
        if (parsed < 0) return 0
        if (parsed > maxIndex) return maxIndex
        return parsed
      }

      function setActiveGallery(index) {
        if (!galleryData.length) return
        activeGalleryIndex = normalizeGalleryIndex(index, 0)
        var item = galleryData[activeGalleryIndex]

        if (galleryMainImage && galleryMainImage instanceof HTMLImageElement) {
          galleryMainImage.src = item.url
          galleryMainImage.alt = item.alt || item.title || document.title
          galleryMainImage.dataset.galleryCurrentIndex = safeText(activeGalleryIndex)
        }

        galleryThumbs.forEach(function (button) {
          var thumbIndex = normalizeGalleryIndex(button.dataset.galleryThumbIndex, -1)
          if (thumbIndex === -1) return
          button.classList.toggle('gallery-thumb--active', thumbIndex === activeGalleryIndex)
          button.setAttribute('aria-current', thumbIndex === activeGalleryIndex ? 'true' : 'false')
        })

        galleryDots.forEach(function (button) {
          var dotIndex = normalizeGalleryIndex(button.dataset.galleryDot, -1)
          if (dotIndex === -1) return
          button.classList.toggle('gallery-dot--active', dotIndex === activeGalleryIndex)
          button.setAttribute('aria-current', dotIndex === activeGalleryIndex ? 'true' : 'false')
        })

        if (galleryModalImage instanceof HTMLImageElement) {
          galleryModalImage.src = item.url
          galleryModalImage.alt = item.alt || item.title || document.title
        }

        if (galleryModalCounter) {
          galleryModalCounter.textContent = activeGalleryIndex + 1 + ' / ' + galleryData.length
        }

        galleryModalThumbs.forEach(function (button) {
          var thumbIndex = normalizeGalleryIndex(button.getAttribute('data-gallery-modal-thumb'), -1)
          if (thumbIndex === -1) return
          button.classList.toggle('gallery-modal__thumb--active', thumbIndex === activeGalleryIndex)
          button.setAttribute('aria-current', thumbIndex === activeGalleryIndex ? 'true' : 'false')
        })
      }

      function setGalleryModalOpen(nextState) {
        if (!(galleryModal instanceof HTMLElement)) return
        isGalleryModalOpen = nextState
        galleryModal.hidden = !nextState
        document.body.classList.toggle('gallery-modal-open', nextState)
      }

      function openGalleryModal(index) {
        setActiveGallery(index)
        setGalleryModalOpen(true)
      }

      if (galleryRoot && typeof galleryRoot.addEventListener === 'function') {
        galleryRoot.addEventListener('click', function (event) {
          var target = event.target
          if (!(target instanceof Element) || !galleryData.length) return

          var thumbButton = target.closest('[data-gallery-thumb-index]')
          if (thumbButton instanceof HTMLElement) {
            var nextThumbIndex = normalizeGalleryIndex(thumbButton.dataset.galleryThumbIndex, 0)
            setActiveGallery(nextThumbIndex)
            thumbButton.scrollIntoView({
              behavior: 'smooth',
              block: 'nearest',
              inline: 'nearest',
            })
            return
          }

          var dotButton = target.closest('[data-gallery-dot]')
          if (dotButton instanceof HTMLElement) {
            var nextDotIndex = normalizeGalleryIndex(dotButton.dataset.galleryDot, 0)
            setActiveGallery(nextDotIndex)
            return
          }

          var actionButton = target.closest('[data-gallery-action]')
          if (!(actionButton instanceof HTMLElement)) return

          if (actionButton.dataset.galleryAction === 'prev') {
            setActiveGallery(activeGalleryIndex > 0 ? activeGalleryIndex - 1 : galleryData.length - 1)
            return
          }

          if (actionButton.dataset.galleryAction === 'next') {
            setActiveGallery(activeGalleryIndex < galleryData.length - 1 ? activeGalleryIndex + 1 : 0)
          }
        })
      }

      if (galleryMain && typeof galleryMain.addEventListener === 'function') {
        galleryMain.addEventListener(
          'touchstart',
          function (event) {
            var touch = event.touches && event.touches[0]
            if (!touch) return
            galleryTouchStartX = touch.clientX
            galleryTouchStartY = touch.clientY
          },
          { passive: true },
        )

        galleryMain.addEventListener(
          'touchend',
          function (event) {
            if (galleryTouchStartX === null || galleryTouchStartY === null || !galleryData.length) return
            var touch = event.changedTouches && event.changedTouches[0]
            if (!touch) return
            var deltaX = touch.clientX - galleryTouchStartX
            var deltaY = touch.clientY - galleryTouchStartY

            galleryTouchStartX = null
            galleryTouchStartY = null

            if (Math.abs(deltaX) < 44 || Math.abs(deltaX) <= Math.abs(deltaY)) return

            if (deltaX < 0) {
              setActiveGallery(activeGalleryIndex < galleryData.length - 1 ? activeGalleryIndex + 1 : 0)
              return
            }

            setActiveGallery(activeGalleryIndex > 0 ? activeGalleryIndex - 1 : galleryData.length - 1)
          },
          { passive: true },
        )
      }

      setActiveGallery(0)

      galleryOpenTriggers.forEach(function (trigger) {
        trigger.addEventListener('click', function (event) {
          event.preventDefault()
          openGalleryModal(activeGalleryIndex)
        })
      })

      galleryModalCloseButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          setGalleryModalOpen(false)
        })
      })

      galleryModalThumbs.forEach(function (button) {
        button.addEventListener('click', function () {
          var nextIndex = normalizeGalleryIndex(button.getAttribute('data-gallery-modal-thumb'), 0)
          setActiveGallery(nextIndex)
        })
      })

      if (galleryModalPrev instanceof HTMLButtonElement) {
        galleryModalPrev.addEventListener('click', function () {
          setActiveGallery(activeGalleryIndex > 0 ? activeGalleryIndex - 1 : galleryData.length - 1)
        })
      }

      if (galleryModalNext instanceof HTMLButtonElement) {
        galleryModalNext.addEventListener('click', function () {
          setActiveGallery(activeGalleryIndex < galleryData.length - 1 ? activeGalleryIndex + 1 : 0)
        })
      }

      document.addEventListener('keydown', function (event) {
        if (!isGalleryModalOpen) return
        if (event.key === 'Escape') {
          setGalleryModalOpen(false)
          return
        }
        if (event.key === 'ArrowLeft') {
          setActiveGallery(activeGalleryIndex > 0 ? activeGalleryIndex - 1 : galleryData.length - 1)
          return
        }
        if (event.key === 'ArrowRight') {
          setActiveGallery(activeGalleryIndex < galleryData.length - 1 ? activeGalleryIndex + 1 : 0)
        }
      })

      function formatSelectedDate(value) {
        if (!value) return 'Выбрать'
        var parsed = new Date(value)
        if (Number.isNaN(parsed.getTime())) return 'Выбрать'
        return parsed.toLocaleDateString('ru-RU', {
          day: '2-digit',
          month: 'short',
        })
      }

      function formatSelectedGuests(value) {
        var amount = Number.parseInt(value || '', 10)
        if (!Number.isFinite(amount) || amount <= 0) return 'Уточнить'
        var lastDigit = amount % 10
        var lastTwoDigits = amount % 100
        var word = 'гостей'
        if (lastDigit === 1 && lastTwoDigits !== 11) word = 'гость'
        if (lastDigit >= 2 && lastDigit <= 4 && (lastTwoDigits < 10 || lastTwoDigits >= 20)) {
          word = 'гостя'
        }
        return amount + ' ' + word
      }

      function syncBookingSelectorState() {
        if (!(leadForm instanceof HTMLFormElement)) return
        var dateField = leadForm.elements.namedItem('requestedDate')
        var guestsField = leadForm.elements.namedItem('peopleCount')

        if (bookingDateSummary && dateField instanceof HTMLInputElement) {
          bookingDateSummary.textContent = formatSelectedDate(dateField.value)
        }

        if (bookingGuestSummary && guestsField instanceof HTMLInputElement) {
          bookingGuestSummary.textContent = formatSelectedGuests(guestsField.value)
        }
      }

      syncBookingSelectorState()

      function focusBookingField(fieldName) {
        if (!(leadForm instanceof HTMLFormElement)) return
        leadForm.scrollIntoView({ behavior: 'smooth', block: 'start' })

        window.setTimeout(function () {
          var field = leadForm.elements.namedItem(fieldName)
          if (
            field instanceof HTMLInputElement ||
            field instanceof HTMLSelectElement ||
            field instanceof HTMLTextAreaElement
          ) {
            field.focus()
          }
        }, 180)
      }

      if (shareButton instanceof HTMLButtonElement) {
        shareButton.addEventListener('click', async function () {
          var originalText = shareButton.textContent || 'Поделиться'
          try {
            if (navigator.share) {
              await navigator.share({
                title: document.title,
                url: window.location.href,
              })
            } else if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(window.location.href)
            }

            shareButton.textContent = 'Ссылка готова'
          } catch (_error) {
            shareButton.textContent = 'Не удалось'
          }

          window.setTimeout(function () {
            shareButton.textContent = originalText
          }, 1400)
        })
      }

      if (favoriteToggle instanceof HTMLButtonElement) {
        favoriteToggle.addEventListener('click', function () {
          var isPressed = favoriteToggle.getAttribute('aria-pressed') === 'true'
          favoriteToggle.setAttribute('aria-pressed', isPressed ? 'false' : 'true')
          favoriteToggle.textContent = isPressed ? '♡ В избранное' : '♥ В избранном'
        })
      }

      bookingSelectorButtons.forEach(function (button) {
        if (!(button instanceof HTMLButtonElement)) return
        button.addEventListener('click', function () {
          var selectorType = button.dataset.bookingSelector
          if (selectorType === 'date') {
            focusBookingField('requestedDate')
            return
          }

          if (selectorType === 'guests') {
            focusBookingField('peopleCount')
          }
        })
      })

      if (leadForm instanceof HTMLFormElement) {
        var dateField = leadForm.elements.namedItem('requestedDate')
        var guestsField = leadForm.elements.namedItem('peopleCount')
        if (dateField instanceof HTMLInputElement) {
          dateField.addEventListener('change', syncBookingSelectorState)
          dateField.addEventListener('input', syncBookingSelectorState)
        }
        if (guestsField instanceof HTMLInputElement) {
          guestsField.addEventListener('change', syncBookingSelectorState)
          guestsField.addEventListener('input', syncBookingSelectorState)
        }
      }

      var bookingActions = Array.from(document.querySelectorAll('[data-booking-action]'))
      bookingActions.forEach(function (actionElement) {
        actionElement.addEventListener('click', function () {
          if (!(leadForm instanceof HTMLFormElement)) return

          leadForm.scrollIntoView({ behavior: 'smooth', block: 'start' })
          setTimeout(function () {
            var firstName = leadForm.querySelector('[name=\"customerName\"]')
            if (firstName instanceof HTMLInputElement) {
              firstName.focus()
            }
          }, 180)
        })
      })

      var bottomNavItems = Array.from(document.querySelectorAll('[data-bottom-nav][data-bottom-target]'))
      var sectionNavLinks = Array.from(document.querySelectorAll('[data-section-nav][data-section-target]'))
      var trackedTargets = Array.from(
        new Set(
          bottomNavItems
            .map(function (item) {
              return item.getAttribute('data-bottom-target')
            })
            .concat(
              sectionNavLinks.map(function (item) {
                return item.getAttribute('data-section-target')
              }),
            )
            .filter(Boolean),
        ),
      )
      var navSections = trackedTargets
        .map(function (targetId) {
          var section = document.getElementById(targetId)
          return section
            ? {
                targetId: targetId,
                section: section,
              }
            : null
        })
        .filter(Boolean)

      function setActiveBottomNav(targetId) {
        bottomNavItems.forEach(function (item) {
          var isActive = item.getAttribute('data-bottom-target') === targetId
          item.classList.toggle('bottom-funnel-menu__item--active', isActive)
          if (isActive) {
            item.setAttribute('aria-current', 'page')
          } else {
            item.removeAttribute('aria-current')
          }
        })

        sectionNavLinks.forEach(function (item) {
          var isActive = item.getAttribute('data-section-target') === targetId
          item.classList.toggle('section-anchor-bar__item--active', isActive)
          if (isActive) {
            item.setAttribute('aria-current', 'page')
          } else {
            item.removeAttribute('aria-current')
          }
        })
      }

      setActiveBottomNav(
        sectionNavLinks[0]
          ? sectionNavLinks[0].getAttribute('data-section-target') || 'section-overview'
          : 'section-overview',
      )

      function syncFixedNavigationState() {
        var headerHeight = siteHeader instanceof HTMLElement ? siteHeader.getBoundingClientRect().height : 0
        document.documentElement.style.setProperty('--site-header-height', Math.round(headerHeight) + 'px')

        if (sectionAnchorBar instanceof HTMLElement) {
          document.documentElement.style.setProperty(
            '--section-anchor-height',
            Math.round(sectionAnchorBar.getBoundingClientRect().height) + 'px',
          )
        }

        if (!(sectionOverview instanceof HTMLElement)) return

        var overviewTop = sectionOverview.getBoundingClientRect().top
        var mobileThreshold = window.innerHeight * 0.9
        var desktopThreshold = headerHeight + 28
        var isDesktop = window.innerWidth >= 1040
        var shouldShow = overviewTop <= (window.innerWidth < 1040 ? mobileThreshold : desktopThreshold)

        if (sectionAnchorBar instanceof HTMLElement) {
          sectionAnchorBar.classList.toggle('section-anchor-bar--visible', shouldShow && isDesktop)
        }

        if (bottomFunnelMenu instanceof HTMLElement) {
          bottomFunnelMenu.classList.toggle('bottom-funnel-menu--visible', shouldShow && !isDesktop)
        }
      }

      if (typeof window.IntersectionObserver === 'function' && navSections.length > 0) {
        var navObserver = new IntersectionObserver(
          function (entries) {
            var visible = entries
              .filter(function (entry) {
                return entry.isIntersecting
              })
              .sort(function (a, b) {
                return b.intersectionRatio - a.intersectionRatio
              })

            if (!visible.length) return

            var current = visible[0]
            var targetRow = navSections.find(function (row) {
              return row.section === current.target
            })
            if (!targetRow || !targetRow.targetId) return

            setActiveBottomNav(targetRow.targetId)
          },
          {
            rootMargin: '-14% 0px -55% 0px',
          },
        )

        navSections.forEach(function (row) {
          navObserver.observe(row.section)
        })
      }

      Array.from(
        document.querySelectorAll(
          '[data-bottom-target]:not([data-booking-action]), [data-section-target]',
        ),
      ).forEach(function (link) {
        link.addEventListener('click', function (event) {
          var targetId =
            link.getAttribute('data-bottom-target') || link.getAttribute('data-section-target')
          if (!targetId) return
          var section = document.getElementById(targetId)
          if (!section) return
          event.preventDefault()
          section.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      })

      if (reviewFeed instanceof HTMLElement && reviewCards.length > 0) {
        var activeReviewFilter = 'all'
        var reviewExpandAll = false

        function parseReviewDate(value) {
          var parsed = Date.parse(value || '')
          return Number.isFinite(parsed) ? parsed : 0
        }

        function sortReviewCards(cards) {
          var mode =
            reviewSort instanceof HTMLSelectElement ? reviewSort.value : 'relevance'
          var nextCards = cards.slice()

          if (mode === 'newest') {
            nextCards.sort(function (left, right) {
              return parseReviewDate(right.dataset.reviewDate) - parseReviewDate(left.dataset.reviewDate)
            })
            return nextCards
          }

          if (mode === 'oldest') {
            nextCards.sort(function (left, right) {
              return parseReviewDate(left.dataset.reviewDate) - parseReviewDate(right.dataset.reviewDate)
            })
            return nextCards
          }

          if (mode === 'highest') {
            nextCards.sort(function (left, right) {
              return Number.parseFloat(right.dataset.reviewRating || '0') - Number.parseFloat(left.dataset.reviewRating || '0')
            })
            return nextCards
          }

          if (mode === 'lowest') {
            nextCards.sort(function (left, right) {
              return Number.parseFloat(left.dataset.reviewRating || '0') - Number.parseFloat(right.dataset.reviewRating || '0')
            })
            return nextCards
          }

          nextCards.sort(function (left, right) {
            return Number.parseInt(left.dataset.reviewIndex || '0', 10) - Number.parseInt(right.dataset.reviewIndex || '0', 10)
          })
          return nextCards
        }

        function applyReviewFilters() {
          var query =
            reviewSearch instanceof HTMLInputElement ? reviewSearch.value.trim().toLowerCase() : ''

          var filtered = reviewCards.filter(function (card) {
            var rating = Math.round(Number.parseFloat(card.dataset.reviewRating || '0'))
            var matchesFilter = activeReviewFilter === 'all' || String(rating) === activeReviewFilter
            var haystack = card.dataset.reviewSearchText || ''
            var matchesSearch = !query || haystack.indexOf(query) !== -1
            return matchesFilter && matchesSearch
          })

          filtered = sortReviewCards(filtered)
          filtered.forEach(function (card) {
            reviewFeed.appendChild(card)
          })

          reviewCards.forEach(function (card) {
            card.hidden = filtered.indexOf(card) === -1
          })

          filtered.forEach(function (card, index) {
            card.hidden = !reviewExpandAll && index >= 6
          })

          if (reviewEmpty instanceof HTMLElement) {
            reviewEmpty.hidden = filtered.length > 0
          }

          if (reviewShowMore instanceof HTMLButtonElement) {
            reviewShowMore.hidden = filtered.length <= 6
            reviewShowMore.textContent = reviewExpandAll ? 'Свернуть отзывы' : 'Показать еще отзывы'
          }
        }

        reviewFilterButtons.forEach(function (button) {
          button.addEventListener('click', function () {
            activeReviewFilter = button.getAttribute('data-review-filter') || 'all'
            reviewExpandAll = false
            reviewFilterButtons.forEach(function (item) {
              var isActive = item === button
              item.classList.toggle('review-filter-chip--active', isActive)
              item.setAttribute('aria-pressed', isActive ? 'true' : 'false')
            })
            applyReviewFilters()
          })
        })

        if (reviewSearch instanceof HTMLInputElement) {
          reviewSearch.addEventListener('input', function () {
            reviewExpandAll = false
            applyReviewFilters()
          })
        }

        if (reviewSort instanceof HTMLSelectElement) {
          reviewSort.addEventListener('change', function () {
            applyReviewFilters()
          })
        }

        if (reviewShowMore instanceof HTMLButtonElement) {
          reviewShowMore.addEventListener('click', function () {
            reviewExpandAll = !reviewExpandAll
            applyReviewFilters()
          })
        }

        reviewCards.forEach(function (card) {
          var toggle = card.querySelector('[data-review-toggle]')
          var text = card.querySelector('[data-review-text]')
          if (!(toggle instanceof HTMLButtonElement) || !(text instanceof HTMLElement)) return
          toggle.addEventListener('click', function () {
            var isExpanded = toggle.getAttribute('aria-expanded') === 'true'
            toggle.setAttribute('aria-expanded', isExpanded ? 'false' : 'true')
            text.classList.toggle('review-card__text--clamped', isExpanded)
            toggle.textContent = isExpanded ? 'Читать дальше' : 'Свернуть'
          })
        })

        applyReviewFilters()
      }

      discoveryCarousels.forEach(function (carousel) {
        var viewport = carousel.querySelector('[data-carousel-viewport]')
        var track = carousel.querySelector('[data-carousel-track]')
        var prev = carousel.querySelector('[data-carousel-prev]')
        var next = carousel.querySelector('[data-carousel-next]')
        var pageLabel = carousel.querySelector('[data-carousel-page]')
        var totalLabel = carousel.querySelector('[data-carousel-pages]')
        var meta = carousel.querySelector('[data-carousel-meta]')

        if (!(viewport instanceof HTMLElement) || !(track instanceof HTMLElement)) return

        function getCarouselMetrics() {
          var cards = Array.from(track.querySelectorAll('.experience-card'))
          if (!cards.length) {
            return {
              current: 1,
              pages: 1,
              scrollStep: viewport.clientWidth,
            }
          }

          var firstCard = cards[0]
          var trackStyles = window.getComputedStyle(track)
          var gap = Number.parseFloat(trackStyles.columnGap || trackStyles.gap || '0') || 0
          var cardWidth = firstCard.getBoundingClientRect().width + gap
          var cardsPerPage = Math.max(1, Math.floor((viewport.clientWidth + gap) / Math.max(cardWidth, 1)))
          var pages = Math.max(1, Math.ceil(cards.length / cardsPerPage))
          var scrollStep = cardsPerPage * cardWidth
          var current = Math.min(pages, Math.max(1, Math.round(viewport.scrollLeft / Math.max(scrollStep, 1)) + 1))

          return {
            current: current,
            pages: pages,
            scrollStep: scrollStep,
          }
        }

        function updateCarouselState() {
          var metrics = getCarouselMetrics()
          var pages = metrics.pages
          var current = metrics.current

          if (pageLabel) pageLabel.textContent = String(current)
          if (totalLabel) totalLabel.textContent = String(pages)
          if (prev instanceof HTMLButtonElement) prev.disabled = current <= 1
          if (next instanceof HTMLButtonElement) next.disabled = current >= pages
          if (meta instanceof HTMLElement) meta.hidden = pages <= 1
        }

        if (prev instanceof HTMLButtonElement) {
          prev.addEventListener('click', function () {
            var metrics = getCarouselMetrics()
            viewport.scrollBy({ left: -metrics.scrollStep, behavior: 'smooth' })
          })
        }

        if (next instanceof HTMLButtonElement) {
          next.addEventListener('click', function () {
            var metrics = getCarouselMetrics()
            viewport.scrollBy({ left: metrics.scrollStep, behavior: 'smooth' })
          })
        }

        viewport.addEventListener('scroll', updateCarouselState, { passive: true })
        window.addEventListener('resize', updateCarouselState)
        updateCarouselState()
        window.requestAnimationFrame(updateCarouselState)
        window.setTimeout(updateCarouselState, 250)
        window.addEventListener('load', updateCarouselState, { once: true })
      })

      syncFixedNavigationState()
      window.addEventListener('scroll', syncFixedNavigationState, { passive: true })
      window.addEventListener('resize', syncFixedNavigationState)

      if (leadForm && leadForm instanceof HTMLFormElement && leadFormResult instanceof HTMLDivElement) {
        var leadFormResultElement = leadFormResult
        var leadContactStep = document.getElementById('lead-contact-step')
        var leadContactStepResult = document.getElementById('lead-contact-step-result')
        var leadFollowUpStep = document.getElementById('lead-followup-step')
        var leadFollowUpMessages = document.getElementById('lead-followup-messages')
        var leadFollowUpForm = document.getElementById('lead-followup-form')
        var leadFollowUpAnswerLabel = document.getElementById('lead-followup-answer-label')
        var leadFollowUpAnswer = document.getElementById('lead-followup-answer')
        var leadFollowUpSubmit = document.getElementById('lead-followup-submit')
        var leadFollowUpResult = document.getElementById('lead-followup-result')
        var leadContactButtons = Array.prototype.slice.call(
          document.querySelectorAll('[data-lead-contact-channel]'),
        )
        var latestLeadId = ''
        var currentFollowUpFlow = null
        var currentFollowUpQuestionIndex = 0
        var currentFollowUpAnswers = []

        function setLeadFormResult(text, state) {
          leadFormResultElement.textContent = text
          leadFormResultElement.classList.remove('lead-result--success', 'lead-result--error')
          if (state === 'success') {
            leadFormResultElement.classList.add('lead-result--success')
            return
          }
          if (state === 'error') {
            leadFormResultElement.classList.add('lead-result--error')
          }
        }

        function setLeadContactStepVisible(isVisible) {
          if (!(leadContactStep instanceof HTMLDivElement)) return
          if (isVisible) {
            leadContactStep.removeAttribute('hidden')
            return
          }
          leadContactStep.setAttribute('hidden', '')
        }

        function setLeadFollowUpStepVisible(isVisible) {
          if (!(leadFollowUpStep instanceof HTMLDivElement)) return
          if (isVisible) {
            leadFollowUpStep.removeAttribute('hidden')
            return
          }
          leadFollowUpStep.setAttribute('hidden', '')
        }

        function setLeadFollowUpResult(text, state) {
          if (!(leadFollowUpResult instanceof HTMLDivElement)) return
          leadFollowUpResult.textContent = text
          leadFollowUpResult.classList.remove(
            'lead-followup-step__result--success',
            'lead-followup-step__result--error',
          )
          if (state === 'success') {
            leadFollowUpResult.classList.add('lead-followup-step__result--success')
            return
          }
          if (state === 'error') {
            leadFollowUpResult.classList.add('lead-followup-step__result--error')
          }
        }

        function appendLeadFollowUpMessage(text, role) {
          if (!(leadFollowUpMessages instanceof HTMLDivElement)) return
          var message = document.createElement('p')
          message.className = 'lead-followup-step__message lead-followup-step__message--' + role
          message.textContent = text
          leadFollowUpMessages.appendChild(message)
        }

        function resetLeadFollowUpStep() {
          currentFollowUpFlow = null
          currentFollowUpQuestionIndex = 0
          currentFollowUpAnswers = []
          setLeadFollowUpStepVisible(false)
          setLeadFollowUpResult('', 'idle')
          if (leadFollowUpMessages instanceof HTMLDivElement) {
            leadFollowUpMessages.textContent = ''
          }
          if (leadFollowUpAnswer instanceof HTMLTextAreaElement) {
            leadFollowUpAnswer.value = ''
            leadFollowUpAnswer.removeAttribute('hidden')
            leadFollowUpAnswer.disabled = false
          }
          if (leadFollowUpAnswerLabel instanceof HTMLLabelElement) {
            leadFollowUpAnswerLabel.textContent = ''
          }
          if (leadFollowUpSubmit instanceof HTMLButtonElement) {
            leadFollowUpSubmit.textContent = 'Отправить менеджеру'
            leadFollowUpSubmit.disabled = false
          }
          if (leadFollowUpForm instanceof HTMLFormElement) {
            leadFollowUpForm.removeAttribute('hidden')
          }
        }

        function followUpEndpoint(leadId, suffix) {
          return new URL(
            './' + encodeURIComponent(leadId) + suffix,
            leadApiEndpoint.endsWith('/') ? leadApiEndpoint : leadApiEndpoint + '/',
          ).toString()
        }

        function buildFollowUpComment() {
          return currentFollowUpAnswers
            .map(function (answer) {
              return answer.prompt + ': ' + answer.value
            })
            .join('\n')
        }

        function renderFollowUpQuestion() {
          if (!currentFollowUpFlow) return

          var questions = Array.isArray(currentFollowUpFlow.questions)
            ? currentFollowUpFlow.questions
            : []
          var question = questions[currentFollowUpQuestionIndex]

          if (!question) {
            if (leadFollowUpForm instanceof HTMLFormElement) {
              leadFollowUpForm.setAttribute('hidden', '')
            }
            appendLeadFollowUpMessage(
              safeText(currentFollowUpFlow.finalMessage) ||
                'Все отлично, в ближайшее время менеджер с вами свяжется.',
              'manager',
            )
            setLeadFollowUpResult('', 'success')
            return
          }

          if (leadFollowUpForm instanceof HTMLFormElement) {
            leadFollowUpForm.removeAttribute('hidden')
          }
          if (leadFollowUpAnswerLabel instanceof HTMLLabelElement) {
            leadFollowUpAnswerLabel.textContent = safeText(question.prompt)
          }
          if (leadFollowUpAnswer instanceof HTMLTextAreaElement) {
            leadFollowUpAnswer.value = ''
            leadFollowUpAnswer.placeholder =
              safeText(question.placeholder) || 'Напишите ответ менеджеру'
            if (question.kind === 'instruction') {
              leadFollowUpAnswer.setAttribute('hidden', '')
            } else {
              leadFollowUpAnswer.removeAttribute('hidden')
              window.setTimeout(function () {
                leadFollowUpAnswer.focus()
              }, 0)
            }
          }
          if (leadFollowUpSubmit instanceof HTMLButtonElement) {
            leadFollowUpSubmit.textContent =
              question.kind === 'instruction' ? 'Понятно' : 'Отправить менеджеру'
          }

          appendLeadFollowUpMessage(safeText(question.prompt), 'manager')
          setLeadFollowUpResult('', 'idle')
        }

        async function loadLeadFollowUpFlow(leadId, customerName) {
          resetLeadFollowUpStep()
          setLeadFollowUpStepVisible(true)
          appendLeadFollowUpMessage('Спасибо, ' + customerName + '! Заявку передали менеджеру.', 'manager')
          setLeadFollowUpResult('Готовим пару уточняющих вопросов...', 'idle')

          try {
            var response = await fetch(followUpEndpoint(leadId, '/follow-up-flow'), {
              headers: {
                Accept: 'application/json',
              },
            })

            if (!response.ok) {
              var text = await response.text()
              throw new Error(text || ('Ошибка ' + response.status))
            }

            currentFollowUpFlow = await response.json()
            var serviceTitle = safeText(currentFollowUpFlow && currentFollowUpFlow.serviceTitle)
            if (serviceTitle) {
              appendLeadFollowUpMessage(
                'Пока менеджер проверяет "' + serviceTitle + '", ответьте, пожалуйста, на несколько вопросов по одному.',
                'manager',
              )
            }
            renderFollowUpQuestion()
          } catch (error) {
            var errorMessage = error && error.message ? error.message : 'проверьте подключение к серверу'
            setLeadFollowUpResult('Не удалось загрузить уточняющие вопросы: ' + errorMessage, 'error')
          }
        }

        function setLeadContactButtonsDisabled(isDisabled) {
          leadContactButtons.forEach(function (button) {
            if (button instanceof HTMLButtonElement) {
              button.disabled = isDisabled
            }
          })
        }

        function setLeadContactStepResult(text, state) {
          if (!(leadContactStepResult instanceof HTMLDivElement)) return
          leadContactStepResult.textContent = text
          leadContactStepResult.classList.remove(
            'lead-contact-step__result--success',
            'lead-contact-step__result--error',
          )
          if (state === 'success') {
            leadContactStepResult.classList.add('lead-contact-step__result--success')
            return
          }
          if (state === 'error') {
            leadContactStepResult.classList.add('lead-contact-step__result--error')
          }
        }

        function resetLeadContactStep() {
          latestLeadId = ''
          resetLeadFollowUpStep()
          setLeadContactStepVisible(false)
          setLeadContactButtonsDisabled(false)
          setLeadContactStepResult('', 'idle')
          leadContactButtons.forEach(function (button) {
            if (button instanceof HTMLButtonElement) {
              button.setAttribute('aria-pressed', 'false')
            }
          })
        }

        var leadApiEndpoint =
          leadForm.dataset.leadEndpoint || new URL('/api/catalog/leads', window.location.origin).toString()

        resetLeadContactStep()

        leadForm.addEventListener('submit', async function (event) {
          event.preventDefault()

          var formData = new FormData(leadForm)
          var rawPeople = safeText(formData.get('peopleCount')).trim()
          var peopleCount = rawPeople ? Number(rawPeople) : undefined

          var payload = {
            excursionId: safeText(formData.get('excursionId')).trim(),
            customerName: safeText(formData.get('customerName')).trim(),
            customerPhone: safeText(formData.get('customerPhone')).trim(),
            customerTelegram: safeText(formData.get('customerTelegram')).trim() || undefined,
            requestedDate: safeText(formData.get('requestedDate')).trim() || undefined,
            peopleCount: Number.isFinite(peopleCount) ? peopleCount : undefined,
            comment: safeText(formData.get('comment')).trim() || undefined,
            source: 'website',
            sourcePage: safeText(formData.get('sourcePage')).trim() || window.location.pathname,
          }

          resetLeadContactStep()
          setLeadFormResult('Отправляем заявку...', 'idle')

          try {
            var response = await fetch(leadApiEndpoint, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Accept: 'application/json',
              },
              body: JSON.stringify(payload),
            })

            if (!response.ok) {
              var text = await response.text()
              throw new Error(text || ('Ошибка ' + response.status))
            }

            var responseBody = await response.json()
            var createdLeadId =
              responseBody &&
              responseBody.lead &&
              typeof responseBody.lead.id === 'string'
                ? responseBody.lead.id
                : ''

            if (!createdLeadId) {
              throw new Error('Не удалось получить идентификатор заявки')
            }

            latestLeadId = createdLeadId
            setLeadFormResult(
              'Спасибо! Заявка отправлена менеджеру.',
              'success',
            )
            setLeadContactStepVisible(true)
            await loadLeadFollowUpFlow(createdLeadId, payload.customerName || 'спасибо')
            leadForm.reset()
            syncBookingSelectorState()
          } catch (error) {
            var errorMessage = error && error.message ? error.message : 'проверьте подключение к серверу'
            setLeadFormResult('Не удалось отправить заявку: ' + errorMessage, 'error')
          }
        })

        leadContactButtons.forEach(function (button) {
          if (!(button instanceof HTMLButtonElement)) return

          button.addEventListener('click', async function () {
            if (!latestLeadId) return

            var contactChannel = safeText(button.dataset.leadContactChannel).trim()
            if (!contactChannel) return

            setLeadContactButtonsDisabled(true)
            setLeadContactStepResult('Сохраняем выбранный канал связи...', 'idle')

            try {
              var contactChannelEndpoint = new URL(
                './' + encodeURIComponent(latestLeadId) + '/contact-channel',
                leadApiEndpoint.endsWith('/') ? leadApiEndpoint : leadApiEndpoint + '/',
              ).toString()

              var response = await fetch(contactChannelEndpoint, {
                method: 'PATCH',
                headers: {
                  'Content-Type': 'application/json',
                  Accept: 'application/json',
                },
                body: JSON.stringify({
                  contactChannel: contactChannel,
                }),
              })

              if (!response.ok) {
                var text = await response.text()
                throw new Error(text || ('Ошибка ' + response.status))
              }

              leadContactButtons.forEach(function (candidate) {
                if (candidate instanceof HTMLButtonElement) {
                  candidate.setAttribute(
                    'aria-pressed',
                    String(candidate.dataset.leadContactChannel === contactChannel),
                  )
                }
              })

              setLeadContactStepResult(
                'Канал связи сохранён. Менеджер продолжит общение через ' + button.textContent + '.',
                'success',
              )
            } catch (error) {
              var errorMessage = error && error.message ? error.message : 'проверьте подключение к серверу'
              setLeadContactStepResult(
                'Не удалось сохранить канал связи: ' + errorMessage,
                'error',
              )
            } finally {
              setLeadContactButtonsDisabled(false)
            }
          })
        })

        if (leadFollowUpForm instanceof HTMLFormElement) {
          leadFollowUpForm.addEventListener('submit', async function (event) {
            event.preventDefault()
            if (!latestLeadId || !currentFollowUpFlow) return

            var questions = Array.isArray(currentFollowUpFlow.questions)
              ? currentFollowUpFlow.questions
              : []
            var question = questions[currentFollowUpQuestionIndex]
            if (!question) return

            if (question.kind === 'instruction') {
              currentFollowUpQuestionIndex += 1
              renderFollowUpQuestion()
              return
            }

            var answer =
              leadFollowUpAnswer instanceof HTMLTextAreaElement
                ? leadFollowUpAnswer.value.trim()
                : ''

            if (!answer && question.isRequired) {
              setLeadFollowUpResult('Напишите ответ, чтобы менеджер получил детали.', 'error')
              return
            }

            if (!answer) {
              currentFollowUpQuestionIndex += 1
              renderFollowUpQuestion()
              return
            }

            currentFollowUpAnswers.push({
              key: safeText(question.key),
              prompt: safeText(question.prompt),
              value: answer,
            })
            appendLeadFollowUpMessage(answer, 'customer')
            setLeadFollowUpResult('Передаем менеджеру...', 'idle')
            if (leadFollowUpSubmit instanceof HTMLButtonElement) {
              leadFollowUpSubmit.disabled = true
            }

            try {
              var response = await fetch(followUpEndpoint(latestLeadId, '/follow-up'), {
                method: 'PATCH',
                headers: {
                  'Content-Type': 'application/json',
                  Accept: 'application/json',
                },
                body: JSON.stringify({
                  comment: buildFollowUpComment(),
                  answers: currentFollowUpAnswers.map(function (answer, index) {
                    return {
                      questionKey: answer.key,
                      questionPrompt: answer.prompt,
                      answer: answer.value,
                      sortOrder: (index + 1) * 10,
                    }
                  }),
                }),
              })

              if (!response.ok) {
                var text = await response.text()
                throw new Error(text || ('Ошибка ' + response.status))
              }

              currentFollowUpQuestionIndex += 1
              setLeadFollowUpResult('Передали менеджеру.', 'success')
              renderFollowUpQuestion()
            } catch (error) {
              currentFollowUpAnswers.pop()
              var errorMessage = error && error.message ? error.message : 'проверьте подключение к серверу'
              setLeadFollowUpResult('Не удалось передать ответ: ' + errorMessage, 'error')
            } finally {
              if (leadFollowUpSubmit instanceof HTMLButtonElement) {
                leadFollowUpSubmit.disabled = false
              }
            }
          })
        }
      }
    </script>
  </body>
</html>

<style>
  :root {
    --site-header-height: 72px;
    --section-anchor-height: 0px;
    color-scheme: light;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #fff;
    color: #171f1d;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: #fff;
  }

  a,
  button {
    color: inherit;
    font: inherit;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: auto minmax(220px, 420px) auto;
    gap: 22px;
    align-items: center;
    border-bottom: 1px solid #e6ebe9;
    background: rgba(255, 255, 255, 0.98);
    padding: 10px max(24px, calc((100vw - 1180px) / 2));
    backdrop-filter: blur(12px);
  }

  .brand {
    font-size: 1.15rem;
    font-weight: 900;
    text-decoration: none;
  }

  .search-pill {
    display: flex;
    gap: 12px;
    align-items: center;
    min-height: 42px;
    border: 1px solid #dfe5e3;
    border-radius: 999px;
    padding: 0 18px;
    box-shadow: 0 5px 18px rgba(28, 45, 41, 0.08);
  }

  .search-pill span {
    width: 14px;
    height: 14px;
    border: 2px solid #17211f;
    border-radius: 999px;
  }

  .site-header nav {
    display: flex;
    justify-content: flex-end;
    gap: 20px;
    color: #384641;
    font-size: 0.95rem;
  }

  .site-header a {
    text-decoration: none;
  }

  .tour-page {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 18px 0 74px;
  }

  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    align-items: center;
    margin-bottom: 18px;
    color: #4e5b58;
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .product-head {
    margin-bottom: 16px;
  }

  .badge-row,
  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 13px;
    align-items: center;
  }

  .badge-row {
    margin-bottom: 14px;
  }

  .badge-row span {
    border: 1px solid #dfe7e4;
    border-radius: 999px;
    background: #f6faf8;
    padding: 7px 12px;
    color: #2d5148;
    font-size: 0.86rem;
    font-weight: 780;
  }

  .trust-row {
    color: #33423f;
    font-size: 0.94rem;
    align-items: center;
    gap: 14px;
  }

  .rating-link-wrap {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .trust-row > span:not(.divider):not(.rating-link-wrap):not(.trust-row__meta) {
    width: 1px;
    height: 18px;
    background: #cdd7d3;
  }

  .divider {
    width: 1px;
    height: 18px;
    display: inline-block;
    background: #cdd7d3;
    margin: 0 2px;
  }

  .rating-link {
    color: #0f2a1f;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    text-decoration: none;
  }

  .rating-link strong {
    font-size: 1rem;
    color: #133c29;
  }

  .rating-link__meta {
    color: #5f6b67;
    text-decoration: none;
  }

  .rating-link__meta span:last-child {
    color: #1f5a38;
    font-weight: 700;
  }

  .trust-row__meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #66756f;
  }

  .trust-row__meta span:first-child {
    color: #133c29;
  }

  .reviews-meta {
    color: #17211f;
  }

  .reviews-summary {
    border: 1px solid #d7e2de;
    border-radius: 10px;
    padding: 14px 16px;
    background: #f8fbfa;
    margin-bottom: 16px;
  }

  .reviews-summary__stats {
    display: grid;
    gap: 3px;
  }

