---
import {
  cardImageUrls,
  categoryTitle,
  formatRub,
  formatThb,
  galleryImages,
  loadCatalog,
  loadExcursion,
  loadExcursionReviews,
} from '../../lib/catalog'
import type { ExcursionCardDto } from '@phuket-go/contracts'

export const prerender = true

export async function getStaticPaths() {
  const catalog = await loadCatalog()
  if (catalog.status !== 'ready') return []

  return catalog.excursions.map((excursion) => ({
    params: { slug: excursion.slug },
  }))
}

const slug = Astro.params.slug

if (!slug) {
  throw new Error('Excursion slug is required')
}

const [{ apiUrl, excursion }, catalog, { reviews: excursionReviews }] = await Promise.all([
  loadExcursion(slug),
  loadCatalog(),
  loadExcursionReviews(slug),
])
const images = galleryImages(excursion, apiUrl)
const galleryPreview = images.slice(0, 6)
const mobileGalleryPreview = images.slice(0, 12)
const railGallery = images.slice(0, 8)
const mainImage = images[0] ?? null
const pageTitle = `${excursion.title} - Phuket Go`
const pageDescription = excursion.shortEmotion
const descriptionParagraphs = excursion.description
  .split(/\n{2,}/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean)
const routeItems =
  excursion.route
    ?.split('\n')
    .map((item) => item.replace(/^- /, '').trim())
    .filter(Boolean) ?? []
const includedItems = publicList(excursion.included)
const notIncludedItems = publicList(excursion.notIncluded)
const takeWithYouItems = publicList(excursion.takeWithYou)
const restrictionItems = publicList(excursion.restrictions)
const previewCatalogExcursions =
  catalog.status === 'ready'
    ? catalog.excursions.map((item) => ({
        ...item,
        imageUrl: firstCardImage(item),
      }))
    : []
const currentDiscoveryCard = {
  id: excursion.id,
  slug: excursion.slug,
  title: excursion.title,
  categorySlug: excursion.categorySlug,
  shortEmotion: excursion.shortEmotion,
  priceFromRub: excursion.priceFromRub,
  priceFromThb: excursion.priceFromThb,
  duration: excursion.duration,
  imageUrl: mainImage?.absoluteUrl ?? firstCardImage(excursion),
  externalRating: excursion.externalRating,
  badge: 'Текущая экскурсия',
}
const similarExperienceCards = [
  currentDiscoveryCard,
  ...previewCatalogExcursions
    .filter((item) => item.slug !== excursion.slug && item.categorySlug === excursion.categorySlug)
    .slice(0, 7)
    .map((item) => ({
      ...item,
      badge: null,
    })),
]
const recommendationPool = previewCatalogExcursions.filter(
  (item) => item.slug !== excursion.slug && !similarExperienceCards.some((card) => card.slug === item.slug),
)
const alsoBoughtCards = [
  ...recommendationPool.filter((item) => item.categorySlug === excursion.categorySlug),
  ...recommendationPool.filter((item) => item.categorySlug !== excursion.categorySlug),
]
  .slice(0, 8)
  .map((item) => ({
    ...item,
    badge: null,
  }))
const recentlyViewedCards = [currentDiscoveryCard]
const exploreLinkGroups = [
