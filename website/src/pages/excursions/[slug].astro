const formattedReviewCount =
  typeof trustSummary?.reviewCount === 'number' ? trustSummary.reviewCount.toString() : '0'
const trustSourceLabel = trustSummary?.source ?? 'TripAdvisor'
const trustSourceUrl = trustSummary?.url ?? '#reviews'
const visibleReviewCount = Number(formattedReviewCount) || 0
const normalizedReviewCount = Number.isFinite(visibleReviewCount) ? Math.min(visibleReviewCount, 999) : 0
const trustSummaryText = hasTrustSummary ? `${formattedReviewCount} отзывов` : 'Отзывы в пути'
const displayReviewItems = excursionReviews?.items ?? []
const featuredReview = displayReviewItems[0] ?? null
const travelerLoveTags = ['Все', categoryTitle(excursion.categorySlug), 'Русский гид']
const travelerLoveCards = displayReviewItems.slice(0, 2)
const reviewStarFilters = [
  { key: 'all', label: 'Все', count: displayReviewItems.length },
  ...[5, 4, 3, 2, 1].map((star) => ({
    key: String(star),
    label: `${star}★`,
    count: displayReviewItems.filter((item) => Math.round(item.rating ?? 0) === star).length,
  })),
].filter((item) => item.key === 'all' || item.count > 0)
const leadEndpoint = new URL('/api/catalog/leads', apiUrl).toString()
const contactChannels = [
  { value: 'telegram', label: 'Telegram' },
  { value: 'whatsapp', label: 'WhatsApp' },
  { value: 'max', label: 'Max' },
]
const initialGuestCount = 2

const bottomMenuIconSet: Record<string, string> = {
