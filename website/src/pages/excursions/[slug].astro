  },
]
function formatReviewDate(value: string | null) {
  if (!value) return null
  const parsed = new Date(value)
  if (Number.isNaN(parsed.getTime())) return value

  return parsed.toLocaleDateString('ru-RU', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  })
}

function ratingStars(value: number | null | undefined) {
  const safe = value ?? 0
  const rounded = Math.max(0, Math.min(5, Math.round(safe * 2) / 2))
  const full = Math.floor(rounded)
  const half = rounded % 1 === 0.5
  const empty = 5 - full - (half ? 1 : 0)
  return '★'.repeat(full) + (half ? '☆' : '') + '☆'.repeat(Math.max(0, empty))
}

function pluralizeRu(count: number, one: string, few: string, many: string) {
  const mod10 = count % 10
  const mod100 = count % 100
  if (mod10 === 1 && mod100 !== 11) return one
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 10 || mod100 >= 20)) return few
  return many
}

function firstCardImage(item: ExcursionCardDto) {
  const [url] = cardImageUrls(item, apiUrl)
  return url ?? null
}

function publicList(items: string[]) {
  return items.flatMap(splitPublicItem).map(publicText).filter(Boolean)
}

function splitPublicItem(item: string) {
  if (item.length < 90) return [item]
  return item
    .split(/,\s*/)
    .map((part) => part.trim())
    .filter((part) => part.length > 0)
}

function publicText(value: string) {
  const normalized = value.trim().replace(/\.$/, '')
  if (normalized.toLowerCase().includes('англоязычный гид')) {
    return 'Русский гид'
  }

  return normalized
}

function discoveryLocationLabel(_categorySlug: string) {
  if (_categorySlug === 'sea-tours' || _categorySlug === 'water-transport') {
    return 'Пхукет и острова Андаманского моря'
  }

  if (_categorySlug === 'land-tours' || _categorySlug === 'active') {
    return 'Пхукет и соседние провинции'
  }

  return 'Пхукет, Таиланд'
}
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Phuket Go</a>
      <div class="search-pill" aria-label="Поиск">
        <span></span>
        <strong>Пхукет</strong>
      </div>
      <nav aria-label="Основная навигация">
        <a href="/">Экскурсии</a>
        <a href="/articles">Статьи</a>
        <a href="/faq">FAQ</a>
        <a href="/contacts">Контакты</a>
        <a href="/booking-terms">Условия</a>
        <a href="/#sea-tours">Морские туры</a>
        <a href="/#land-tours">Наземные туры</a>
      </nav>
    </header>

    <main class="tour-page">
      <nav class="breadcrumbs" aria-label="Хлебные крошки">
        <a href="/">Все экскурсии на Пхукете</a>
        <span>/</span>
        <a href="/">Главная</a>
        <span>/</span>
        <a href="/">{categoryTitle(excursion.categorySlug)}</a>
        <span>/</span>
        <span>{excursion.title}</span>
      </nav>
    
    <section class="product-head" aria-labelledby="page-title">
        <div class="badge-row" aria-label="Преимущества">
          <span>Бесплатное бронирование</span>
          <span>{categoryTitle(excursion.categorySlug)}</span>
          <span>Пхукет, Таиланд</span>
        </div>
        <h1 id="page-title">{excursion.title}</h1>
      <div class="trust-row">
        <div class="rating-link-wrap">
          {hasTrustSummary ? (
            <>
              <a
                class="rating-link"
                href={trustSourceUrl}
                rel="noreferrer noopener"
                target="_blank"
                aria-label={`Открыть рейтинг и отзывы ${trustSourceLabel}`}
              >
                <span class="rating" aria-label={`Рейтинг ${trustSummary?.rating ?? 0}`}>
                  {ratingStars(trustSummary?.rating)}
                </span>
                <strong>{formattedTrustRating}</strong>
              </a>
              <a href="#reviews" class="rating-link__meta">
                <span>{formattedReviewCount}</span>
                <span> отзывов</span>
                <span aria-hidden="true"> • </span>
                <span>{trustSourceLabel}</span>
              </a>
            </>
          ) : (
            <>
              <span class="rating" aria-label="Блок рейтинга">★★★★★ Без оценок</span>
              <a href="#reviews">Отзывы скоро</a>
            </>
          )}
        </div>
        <span class="divider" aria-hidden="true"></span>
        <strong class="reviews-meta">Подходит для активного дня</strong>
        <span class="divider" aria-hidden="true"></span>
        <strong>Пхукет, Таиланд</strong>
      </div>
      </section>

      <section class="product-shell" aria-label="Карточка экскурсии">
        <div class="product-main">
          <section class="viator-gallery" aria-label="Фото экскурсии">
          <script
            id="gallery-data"
            type="application/json"
            is:inline
            set:html={JSON.stringify(
              images.map((image, index) => ({
                index,
                url: image.absoluteUrl,
                alt: image.alt ?? excursion.title,
              })),
            )}
          />
          <div class="gallery-mobile-strip" aria-label="Фото">
            {mobileGalleryPreview.map((image, index) => (
              <button
                class:list={['gallery-thumb', 'gallery-thumb--mobile']}
                type="button"
                data-gallery-thumb-index={index}
                aria-label={`Открыть фото ${index + 1}`}
              >
                <img src={image.absoluteUrl} alt={image.alt ?? excursion.title} loading={index < 2 ? 'eager' : 'lazy'} />
              </button>
            ))}
          </div>

            {galleryPreview.length > 0 && (
              <div class="gallery-rail" aria-label="Миниатюры">
                {railGallery.map((image, index) => (
                  <button
                    class:list={['gallery-thumb', index === 0 && 'gallery-thumb--active']}
                    type="button"
                    data-gallery-thumb-index={index}
                    aria-label={`Открыть фото ${index + 1}`}
                  >
                    <img src={image.absoluteUrl} alt={image.alt ?? excursion.title} loading={index < 3 ? 'eager' : 'lazy'} />
                    {index === railGallery.length - 1 && images.length > railGallery.length && (
                      <span>Еще</span>
                    )}
                  </button>
                ))}
              </div>
            )}
            <figure class="gallery-main">
              {mainImage ? (
                <img
                  id="gallery-main-image"
                  src={mainImage.absoluteUrl}
                  alt={mainImage.alt ?? excursion.title}
                  data-gallery-current-index="0"
                  data-gallery-open="true"
                  loading="eager"
                />
              ) : (
                <div class="gallery-main-placeholder">Фото готовятся</div>
              )}
              <div class="gallery-actions" aria-label="Действия">
                <button type="button" data-share-button>Поделиться</button>
                <button type="button" data-favorite-toggle aria-pressed="false">♡ В избранное</button>
              </div>
              <a class="gallery-more" href="#photos" data-gallery-open="true">{photoCountLabel}</a>
              <button
                class="gallery-arrow gallery-arrow--left"
                type="button"
                aria-label="Предыдущее фото"
                id="gallery-arrow-prev"
                data-gallery-action="prev"
              >
